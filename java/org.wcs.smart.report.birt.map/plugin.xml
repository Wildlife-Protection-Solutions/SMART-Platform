<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.birt.report.model.reportItemModel">
      <reportItem
            class="org.wcs.smart.birt.map.SmartMapFactory"
            extensionName="Smart Map">
         <property
               allowExpression="false"
               defaultDisplayName="Basemap"
               hasOwnModel="false"
               isEncryptable="false"
               name="org.wcs.smart.birt.map.basemap"
               type="string">
         </property>
         <property
               canInherit="true"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.layers"
               subType="string"
               type="list">
         </property>
         <property
               canInherit="true"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.layerNames"
               subType="string"
               type="list">
         </property>
         <property
               canInherit="true"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.layerStyles"
               subType="string"
               type="list">
         </property>
         <property
               canInherit="true"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.bounds"
               type="string">
         </property>
      </reportItem>
   </extension>
   <extension
         point="org.eclipse.birt.report.designer.ui.reportitemUI">
      <model
            extensionName="Smart Map">
      </model>
      <palette
            icon="images/smart16.gif"></palette>
      <editor
            canResize="true"
            showInDesigner="true"
            showInMasterPage="true">
      </editor>
      <outline
            icon="images/smart16.gif">
      </outline>
      <reportItemImageUI
            class="org.wcs.smart.birt.map.SmartMapItemImageUi">
      </reportItemImageUI>
   </extension>
   <extension
         point="org.eclipse.birt.report.engine.reportitemPresentation">
      <reportItem
            class="org.wcs.smart.birt.map.SmartMapPresentationImpl "
            name="Smart Map">
      </reportItem>
   </extension>
   <extension
         point="org.eclipse.birt.report.designer.ui.elementAdapters">
      <adaptable
            class="org.eclipse.birt.report.model.api.ExtendedItemHandle">
         <adapter
               factory="org.wcs.smart.birt.map.properties.SmartMapItemPageGeneratorFactory"
               id="ReportDesign.AttributeView.RotatedTextPageGenerator"
               singleton="false"
               type="org.eclipse.birt.report.designer.ui.views.IPageGenerator">
            <enablement>
               <test
                     forcePluginActivation="true"
                     property=" ExtendItemHandle.extensionName"
                     value="Smart Map">
               </test>
            </enablement>
         </adapter>
      </adaptable>
   </extension>

</plugin>
