<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.birt.report.model.reportItemModel">
      <reportItem
            class="org.wcs.smart.birt.map.SmartMapFactory"
            extensionName="Smart Map">
         <property
               allowExpression="false"
               defaultDisplayName="Basemap"
               hasOwnModel="false"
               isEncryptable="false"
               name="org.wcs.smart.birt.map.basemap"
               type="string">
         </property>
         <property
               canInherit="true"
               defaultDisplayName="Smart Map Layers"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.layers"
               subType="string"
               type="list">
         </property>
         <property
               canInherit="true"
               defaultDisplayName="Smart Map Layer Names"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.layerNames"
               subType="string"
               type="list">
         </property>
         <property
               canInherit="true"
               defaultDisplayName="Smart Map Layer Styles"
               hasOwnModel="true"
               isEncryptable="false"
               isList="false"
               name="org.wcs.smart.birt.map.layerStyles"
               subType="string"
               type="list">
         </property>
         <propertyGroup
               defaultDisplayName="Map Bounds"
               name="org.wcs.smart.report.birt.map.bounds">
            <property
                  canInherit="true"
                  defaultDisplayName="X Min"
                  hasOwnModel="true"
                  isEncryptable="false"
                  isList="false"
                  name="org.wcs.smart.report.birt.map.bounds.xmin"
                  type="float">
            </property>
            <property
                  canInherit="true"
                  defaultDisplayName="X Max"
                  hasOwnModel="true"
                  isEncryptable="false"
                  isList="false"
                  name="org.wcs.smart.report.birt.map.bounds.xmax"
                  type="float">
            </property>
            <property
                  canInherit="true"
                  defaultDisplayName="Y Min"
                  hasOwnModel="true"
                  isEncryptable="false"
                  isList="false"
                  name="org.wcs.smart.report.birt.map.bounds.ymin"
                  type="float">
            </property>
            <property
                  canInherit="true"
                  defaultDisplayName="Y Max"
                  hasOwnModel="true"
                  isEncryptable="false"
                  isList="false"
                  name="org.wcs.smart.report.birt.map.bounds.ymax"
                  type="float">
            </property>
            <property
                  canInherit="true"
                  defaultDisplayName="CRS"
                  hasOwnModel="true"
                  isEncryptable="false"
                  isList="false"
                  name="org.wcs.smart.report.birt.map.bounds.srid"
                  type="string">
            </property>
         </propertyGroup>
         <overrideProperty
               allowedUnits="CM,IN,MM,PT,PC,PX"
               propertyName="width">
         </overrideProperty>
         <overrideProperty
               allowedUnits="CM,IN,MM,PT,PC,PX"
               propertyName="height">
         </overrideProperty>
      </reportItem>
   </extension>
   <extension
         point="org.eclipse.birt.report.designer.ui.reportitemUI">
      <model
            extensionName="Smart Map">
      </model>
      <palette
            icon="images/icons/obj16/map.png"></palette>
      <editor
            canResize="true"
            showInDesigner="true"
            showInMasterPage="true">
      </editor>
      <outline
            icon="images/icons/obj16/map.png">
      </outline>
      <reportItemImageUI
            class="org.wcs.smart.birt.map.SmartMapItemImageUi">
      </reportItemImageUI>
   </extension>
   <extension
         point="org.eclipse.birt.report.engine.reportitemPresentation">
      <reportItem
            class="org.wcs.smart.birt.map.SmartMapPresentationImpl "
            name="Smart Map">
      </reportItem>
   </extension>
   <extension
         point="org.eclipse.birt.report.designer.ui.elementAdapters">
      <adaptable
            class="org.eclipse.birt.report.model.api.ExtendedItemHandle">
         <adapter
               factory="org.wcs.smart.birt.map.properties.SmartMapItemPageGeneratorFactory"
               id="ReportDesign.AttributeView.RotatedTextPageGenerator"
               singleton="false"
               type="org.eclipse.birt.report.designer.ui.views.IPageGenerator">
            <enablement>
               <test
                     forcePluginActivation="true"
                     property=" ExtendItemHandle.extensionName"
                     value="Smart Map">
               </test>
            </enablement>
         </adapter>
      </adaptable>
   </extension>
   <extension
         point="net.refractions.udig.project.ui.tool">
      <category
            id="org.wcs.smart.udig.report.maptools">
      </category>
      <actionTool
            categoryId="org.wcs.smart.udig.report.maptools"
            class="org.wcs.smart.birt.map.tools.ZoomExtentTool"
            icon="images/icons/etool16/zoom_layers.png"
            id="org.wcs.smart.birt.map.tools.ZoomExtents"
            name="Zoom Extents"
            onToolbar="false"
            tooltip="Zoom to map extents">
      </actionTool>
      <modalTool
            categoryId="org.wcs.smart.udig.report.maptools"
            class="org.wcs.smart.birt.map.tools.ZoomTool"
            icon="images/icons/etool16/zoom_mode.gif"
            id="org.wcs.smart.birt.map.tools.Zoom"
            name="Zoom Tool"
            onToolbar="false"
            toolCursorId="zoomCursor"
            tooltip="Zoom the map">
      </modalTool>
      <modalTool
            categoryId="org.wcs.smart.udig.report.maptools"
            class="org.wcs.smart.birt.map.tools.PanTool"
            icon="images/icons/etool16/pan_mode.gif"
            id="org.wcs.smart.birt.map.tools.Pan"
            name="Pan Tool"
            onToolbar="false"
            toolCursorId="move"
            tooltip="Pans the map">
      </modalTool>
   </extension>

</plugin>
