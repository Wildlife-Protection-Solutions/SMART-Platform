   <category-def name="cybertracker" label="SMART CyberTracker Plug-in">
      <description>
         SMART-CyberTracker plug-in provides compatablitily with CybetTracker application. Using this plug-in you will be able to create and deploy CyberTracker applications based on your Data Model or Configurable Model. Plugin also provides the ability to work directly with handheld devices while exporting/importing data doing all the interaction with CyberTracker in background.
      </description>
   </category-def>
   <category-def name="intelligence" label="SMART Intelligence Plug-in">
      <description>
         SMART Intelligence Plug-in contains an intelligence module that allows to organize, maintain and query intelligence information.
      </description>
   </category-def>
   <category-def name="planning" label="SMART Planning Plug-in">
      <description>
         SMART Planning Plug-in contains a plan module that allows to organize, maintain and query planning information.
      </description>
   </category-def>
   <category-def name="smart" label="SMART Application Language Packs"/>
   <category-def name="entity" label="SMART Entity Plug-in">
      <description>
         SMART Entity Plug-in contains a entity module that allows to track idividual entities.
      </description>
   </category-def>
