                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.plan.planPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.plan.exportPdf"
               label="%command.label.exportPlanToPDF"
               style="push"
               tooltip="%exportpdf.command.tooltip.0">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.plan.planPerspective">
                  </equals>
               </with>
            </visibleWhen>
            <parameter
                  name="org.wcs.smart.plan.exportpdf.editor"
                  value="true">
            </parameter>
         </command>
         <command
               commandId="org.eclipse.ui.file.save"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
