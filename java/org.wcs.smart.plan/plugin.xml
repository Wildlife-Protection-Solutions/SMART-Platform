   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.report">
         <menu
               id="org.wcs.smart.plan.menu"
               label="%plan.menu.label"
               mnemonic="%plan.menu.mnemonic">
            <command
                  commandId="org.wcs.smart.plan.NewPlan"
                  icon="images/icons/view16/plan_add.png"
                  label="%plan.menu.command.label.newplan"
                  mnemonic="%plan.menu.command.mnemonic.newplan"
                  style="push"
                  tooltip="%plan.menu.command.tooltip.newplan">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.plan.separator3"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.plan.exportPdf"
                  label="%exportpdf1command.name"
                  style="push">
               <parameter
                     name="org.wcs.smart.plan.exportpdf.editor"
                     value="true">
               </parameter>
            </command>
            <menu
                  label="%plantemplate.menu.label">
               <command
                     commandId="org.wcs.smart.plan.editTemplate"
                     style="push"
                     tooltip="%plantemplate.command.tooltip">
               </command>
               <separator
                     name="org.wcs.smart.plan.template.separator"
                     visible="true">
               </separator>
               <command
                     commandId="org.wcs.smart.plan.revertTemplate"
                     style="push"
                     tooltip="%reverttemplate.command.tooltip">
               </command>
               <command
                     commandId="org.wcs.smart.plan.exportTemplate"
                     style="push"
                     tooltip="%exporttemplate.command.tooltip">
               </command>
               <command
                     commandId="org.wcs.smart.plan.importTemplate"
                     style="push"
                     tooltip="%importtemplate.command.tooltip">
               </command>
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </menu>
            <separator
                  name="org.wcs.smart.plan.separator1"
                  visible="true">
            </separator>
            <command
