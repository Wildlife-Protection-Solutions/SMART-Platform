                  icon="images/icons/view16/plan.png"
                  label="%plan.menu.command.label.viewplans"
                  style="push"
                  tooltip="%plan.menu.command.tooltip.viewplans">
               <parameter
                     name="org.wcs.smart.perspectiveid"
                     value="org.wcs.smart.plan.planPerspective">
               </parameter>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?endof=org.wcs.smart.perspectivesSeperator">
