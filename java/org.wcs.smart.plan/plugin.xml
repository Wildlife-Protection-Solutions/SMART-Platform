   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.plan.ui.handlers.NewPlanHandler$NewPlanHandlerWrapper"
            commandId="org.wcs.smart.plan.NewPlan">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ShowPlanFilter$ShowPlanFilterWrapper"
            commandId="org.wcs.smart.plan.ShowPlanFilter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.DeletePlanHandler$DeletePlanHandlerWrapper"
            commandId="org.wcs.smart.plan.DeletePlan">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <instanceof
                        value="org.wcs.smart.plan.ui.editor.PlanEditorInput">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.TranslatePlanHandler$TranslatePlanHandlerWrapper"
            commandId="org.wcs.smart.plan.translate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.RevertPlanTemplate$RevertPlanTemplateWrapper"
            commandId="org.wcs.smart.plan.revertTemplate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="activeWorkbenchWindow.activePerspective">
               <equals
                     value="org.wcs.smart.plan.PlanReportPerspective">
               </equals>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.EditPlanTemplate$EditPlanTemplateWrapper"
            commandId="org.wcs.smart.plan.editTemplate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ExportPlanPdf$ExportPlanPdfWrapper"
            commandId="org.wcs.smart.plan.exportPdf">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate>
                  <instanceof
                        value="org.wcs.smart.plan.ui.editor.PlanEditorInput">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ExportTemplateHandler$ExportTemplateHandlerWrapper"
            commandId="org.wcs.smart.plan.exportTemplate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="activeWorkbenchWindow.activePerspective">
               <equals
                     value="org.wcs.smart.plan.PlanReportPerspective">
               </equals>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ImportTemplateHandler$ImportTemplateHandlerWrapper"
            commandId="org.wcs.smart.plan.importTemplate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
