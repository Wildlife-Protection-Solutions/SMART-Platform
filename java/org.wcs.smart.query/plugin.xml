<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.wcs.smart.query.export.format" name="Query Export Format" schema="schema/org.wcs.smart.query.export.format.exsd"/>
   <extension-point id="org.wcs.smart.query.property" name="Query Property" schema="schema/org.wcs.smart.query.property.exsd"/>
   <extension-point id="org.wcs.smart.query.filter.patrol" name="Patrol Filter" schema="schema/org.wcs.smart.query.filter.patrol.exsd"/>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            class="org.wcs.smart.query.ui.definition.QueryDefView"
            icon="images/icons/view16/querypatrol.gif"
            id="org.wcs.smart.query.ui.QueryDefView"
            name="%querydef.view.name"
            restorable="true">
      </view>
      <view
            allowMultiple="false"
            class="org.wcs.smart.query.ui.queryfilter.QueryFilterView"
            icon="images/icons/view16/query_filter_op.png"
            id="org.wcs.smart.query.ui.QueryFilter"
            name="%queryfilter.view.name"
            restorable="false">
      </view>
      <view
            class="org.wcs.smart.query.ui.querylist.QueryListView"
            icon="images/icons/view16/query_list.png"
            id="org.wcs.smart.query.QueryListView"
            name="%querylist.view.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.query.ui.observation.QueryResultsEditor"
            default="false"
            icon="images/icons/view16/waypoint_query.png"
            id="org.wcs.smart.query.ui.QueryResultsEditor"
            name="%observationqueryeditor.editor.name">
      </editor>
      <editor
            class="org.wcs.smart.query.ui.summary.SummaryEditor"
            default="false"
            icon="images/icons/view16/summary_query.png"
            id="org.wcs.smart.query.ui.SummaryEditor"
            name="%summaryqueryeditor.editor.name">
      </editor>
      <editor
            class="org.wcs.smart.query.ui.patrol.PatrolQueryResultsEditor"
            default="false"
            icon="images/icons/obj16/patrol_query.png"
            id="org.wcs.smart.query.ui.PatrolQueryResultsEditor"
            name="%patrolqueryeditor.editor.name">
      </editor>
      <editor
            class="org.wcs.smart.query.ui.gridded.GriddedEditor"
            default="false"
            icon="images/icons/obj16/gridded_query.png"
            id="org.wcs.smart.query.ui.GriddedEditor"
            name="%griddedqueryeditor.editor.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.query.internal.ui.QueryPerspective"
            icon="images/icons/view16/querypatrol.gif"
            id="org.wcs.smart.query.SmartQueryPerspective"
            name="%query.perspective.name">
      </perspective>
      <perspective
            class="org.wcs.smart.query.internal.ui.MultiCaQueryPerspective"
            icon="images/icons/view16/querypatrol.gif"
            id="org.wcs.smart.query.SmartMultiCaQueryPerspective"
            name="Multiple Conservation Area Query Perspective">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?after=org.wcs.smart.patrol.PatrolPerspective">
         <command
               commandId="org.wcs.smart.query.QueryPerspective"
               icon="images/icons/view16/querypatrol.gif"
               label="%perspectivetoolbar.showquery.command.label"
               style="push"
               tooltip="%perspectivetoolbar.showquery.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="analyst">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="org.wcs.smart.query.queryToolbar">
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  label="%queryToolbar.createquery.command.label"
                  style="pulldown"
                  tooltip="%queryToolbar.createquery.command.toolbar">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <or>
                        <equals
                              value="org.wcs.smart.query.SmartQueryPerspective">
                        </equals>
                        <equals
                              value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                        </equals>
                     </or>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.query.exportQuery"
                  label="%queryToolbar.exportquery.command.label"
                  style="push"
                  tooltip="%queryToolbar.exportquery.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <or>
                        <equals
                              value="org.wcs.smart.query.SmartQueryPerspective">
                        </equals>
                        <equals
                              value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                        </equals>
                     </or>
                  </with>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.query.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.eclipse.ui.file.save"
                  label="%queryToolbar.savequery.command.label"
                  tooltip="%queryToolbar.savequery.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <or>
                        <equals
                              value="org.wcs.smart.query.SmartQueryPerspective">
                        </equals>
                        <equals
                              value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                        </equals>
                     </or>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.eclipse.ui.file.saveAs"
                  label="%queryToolbar.saveasquery.command.label"
                  tooltip="%queryToolbar.saveasquery.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <or>
                        <equals
                              value="org.wcs.smart.query.SmartQueryPerspective">
                        </equals>
                        <equals
                              value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                        </equals>
                     </or>
                  </with>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.query.ui.QueryDefView">
         <command
               commandId="org.eclipse.ui.file.save"
               label="%querydefview.toolbar.save.command.label"
               tooltip="%querydefview.toolbar.save.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <or>
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                     </equals>
                  </or>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.query.clearQueryDefinition"
               icon="images/icons/etool16/clear.png"
               style="push"
               tooltip="%querydefview.toolbar.clear.command.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.query.runQuery"
               icon="images/icons/etool16/bullet_go.png"
               label="%querydefview.toolbar.run.command.label"
               style="push"
               tooltip="%querydefview.toolbar.run.command.tooltip">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:org.wcs.smart.query.QueryListView">
         <command
               commandId="org.wcs.smart.query.AddFolder"
               icon="images/icons/etool16/folder_add.png"
               label="%querylistview.popup.newfolder.command.label"
               mnemonic="%querylistview.popup.newfolder.command.mnemonic"
               style="push"
               tooltip="%querylistview.popup.newfolder.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="newfolder"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.query.openQuery"
               label="%querylistview.popup.openquery.command.label"
               mnemonic="%querylistview.popup.openquery.command.mnemonic"
               style="push"
               tooltip="%querylistview.popup.openquery.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <iterate>
                  <instanceof
                        value="org.wcs.smart.query.model.QueryInput">
                  </instanceof>
               </iterate>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.query.renameFolder"
               label="%querylistview.popup.rename.command.label"
               mnemonic="%querylistview.popup.rename.command.mnemonic"
               style="push"
               tooltip="%querylistview.popup.rename.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="rename"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.query.translate"
               label="Translate..."
               mnemonic="t"
               style="push"
               tooltip="Provide translations for name">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="rename"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.query.DeleteItem"
               label="%querylistview.popup.delete.command.label"
               mnemonic="%querylistview.popup.delete.command.mnemonic"
               style="push"
               tooltip="%querylistview.popup.delete.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="delete"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.menu.patrol">
         <menu
               id="org.wcs.smart.menu.query"
               label="%menu.query.label"
               mnemonic="%menu.query.mnemonic">
            <menu
                  icon="images/icons/etool16/addquery.png"
                  label="%menu.query.menu.newquery.name"
                  mnemonic="%menu.query.menu.newquery.mnemonic">
               <command
                     commandId="org.wcs.smart.query.createQuery"
                     label="%menu.query.menu.newquery.newobservationquery.command.label"
                     mnemonic="%menu.query.menu.newquery.newobservationquery.command.mnemonic"
                     style="push"
                     tooltip="%menu.query.menu.newquery.newobservationquery.command.tooltip">
               </command>
               <command
                     commandId="org.wcs.smart.query.createPatrolQuery"
                     label="%menu.query.menu.newquery.newpatrolquery.command.label"
                     mnemonic="%menu.query.menu.newquery.newpatrolquery.command.mnemonic"
                     style="push"
                     tooltip="%menu.query.menu.newquery.newpatrolquery.command.tooltip">
               </command>
               <command
                     commandId="org.wcs.smart.query.createSummary"
                     label="%menu.query.menu.newquery.newsummaryquery.command.label"
                     mnemonic="%menu.query.menu.newquery.newsummaryquery.command.mnemonic"
                     style="push"
                     tooltip="%menu.query.menu.newquery.newsummaryquery.command.tooltip">
               </command>
               <command
                     commandId="org.wcs.smart.query.createGriddedSummary"
                     label="%menu.query.menu.newquery.newgridquery.command.label"
                     mnemonic="%menu.query.menu.newquery.newgridquery.command.mnemonic"
                     style="push"
                     tooltip="%menu.query.menu.newquery.newgridquery.command.tooltip">
                  <visibleWhen
                        checkEnabled="false">
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.query.SmartQueryPerspective">
                        </equals>
                     </with>
                  </visibleWhen>
               </command>
            </menu>
            <separator
                  name="org.wcs.smart.query.separator8"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.query.exportQuery"
                  label="%menu.query.exportquery.command.label"
                  mnemonic="%menu.query.exportquery.command.mnemonic"
                  style="push"
                  tooltip="%menu.query.exportquery.command.tooltip">
            </command>
            <command
                  commandId="org.wcs.smart.query.importQuery"
                  icon="images/icons/etool16/importquery.png"
                  label="%menu.query.importquery.command.label"
                  mnemonic="%menu.query.importquery.command.mnemonic"
                  style="push"
                  tooltip="%menu.query.importquery.command.tooltip">
            </command>
            <separator
                  name="org.wcs.smart.query.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.eclipse.ui.file.save"
                  label="%menu.query.savequery.command.label"
                  mnemonic="%menu.query.savequery.command.mnemonic"
                  tooltip="%menu.query.savequery.command.tooltip">
            </command>
            <command
                  commandId="org.eclipse.ui.file.saveAs"
                  label="%menu.query.saveasquery.command.label"
                  mnemonic="%menu.query.saveasquery.command.mnemonic"
                  tooltip="%menu.query.saveasquery.command.tooltip">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="analyst">
                  </test>
               </or>
            </visibleWhen>
            <separator
                  name="org.wcs.smart.query.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.query.QueryPerspective"
                  icon="images/icons/view16/querypatrol.gif"
                  label="%perspectivetoolbar.showquery.command.label"
                  style="push"
                  tooltip="%perspectivetoolbar.showquery.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="analyst">
                     </test>
                  </or>
               </visibleWhen>
            </command>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.file?before=org.wcs.menu.file.changeuserpassword">
         <separator
               name="org.wcs.smart.query.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.eclipse.ui.file.save"
               label="%menu.file.command.save.label"
               mnemonic="%menu.file.command.save.mnemonic"
               tooltip="%menu.file.command.save.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.eclipse.ui.file.saveAs"
               label="%menu.file.command.saveAs.label"
               mnemonic="%menu.file.command.saveAs.mnemonic"
               tooltip="%menu.file.command.saveAs.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.eclipse.ui.file.export"
               label="%menu.file.command.export.label"
               mnemonic="%menu.file.command.export.mnemonic"
               style="push"
               tooltip="%menu.file.command.export.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator3"
               visible="true">
         </separator>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.query.QueryListView">
         <command
               commandId="org.wcs.smart.query.DeleteItem"
               label="%querylist.toolbar.delete.command.label"
               style="push"
               tooltip="%querylist.toolbar.delete.command.tooltip">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.trim.status">
         <toolbar
               id="org.wcs.smart.query.queryError">
            <control
                  class="org.wcs.smart.query.QueryErrorControlContribution">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <or>
                        <equals
                              value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                        </equals>
                        <equals
                              value="org.wcs.smart.query.SmartQueryPerspective">
                        </equals>
                     </or>
                  </with>
               </visibleWhen>
            </control>
         </toolbar>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.query.createUnknownQuery">
         <command
               commandId="org.wcs.smart.query.createQuery"
               label="%querytoolbar.createquery.menu.newobservationquery.command.label"
               style="pulldown"
               tooltip="%querytoolbar.createquery.menu.newobservationquery.command.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.query.createPatrolQuery"
               label="%querytoolbar.createquery.menu.newpatrolquery.command.label"
               style="push"
               tooltip="%querytoolbar.createquery.menu.newpatrolquery.command.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.query.createSummary"
               label="%querytoolbar.createquery.menu.newsummaryquery.command.label"
               style="push"
               tooltip="%querytoolbar.createquery.menu.newsummaryquery.command.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.query.createGriddedSummary"
               label="%querytoolbar.createquery.menu.newgridsummary.command.label"
               style="push"
               tooltip="%querytoolbar.createquery.menu.newgridsummary.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="false"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.query.createPatrolQuery"
            icon="images/icons/obj16/patrol_query.png">
      </image>
      <image
            commandId="org.wcs.smart.query.createQuery"
            icon="images/icons/obj16/waypoint_query.png">
      </image>
      <image
            commandId="org.wcs.smart.query.createSummary"
            icon="images/icons/obj16/summary_query.png">
      </image>
      <image
            commandId="org.wcs.smart.query.exportQuery"
            icon="images/icons/etool16/exportquery.png">
      </image>
      <image
            commandId="org.wcs.smart.query.createGriddedSummary"
            icon="images/icons/obj16/gridded_query.png">
      </image>
      <image
            commandId="org.wcs.smart.query.createUnknownQuery"
            icon="images/icons/etool16/addquery.png">
      </image>
      <image
            commandId="org.wcs.smart.query.DeleteItem"
            icon="images/icons/etool16/delete.png">
      </image>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.query.QueryPerspective"
            name="%showqueryperspective.command.name">
      </command>
      <command
            id="org.wcs.smart.query.createQuery"
            name="%createquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.clearQueryDefinition"
            name="%clearquerydef.command.name">
      </command>
      <command
            id="org.wcs.smart.query.runQuery"
            name="%runquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.exportQuery"
            name="%exportquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.DeleteItem"
            name="%deletequeryorfolder.command.name">
      </command>
      <command
            id="org.wcs.smart.query.AddFolder"
            name="%addsubfolder.command.name">
      </command>
      <command
            id="org.wcs.smart.query.renameFolder"
            name="%renamequeryfolder.command.name">
      </command>
      <command
            id="org.wcs.smart.query.importQuery"
            name="%importquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.createSummary"
            name="%createsummaryquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.createPatrolQuery"
            name="%createpatrolquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.createGriddedSummary"
            name="%creategriddedquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.createUnknownQuery"
            name="%createunknowquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.openQuery"
            name="%openquery.command.name">
      </command>
      <command
            id="org.wcs.smart.query.translate"
            name="Translate...">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.query.internal.ui.ShowQueryPersepctiveHandler"
            commandId="org.wcs.smart.query.QueryPerspective">
      </handler>
      <handler
            class="org.wcs.smart.query.internal.ui.CreateQueryHandler"
            commandId="org.wcs.smart.query.createQuery">
      </handler>
      <handler
            class="org.wcs.smart.query.ui.ClearQueryHandler"
            commandId="org.wcs.smart.query.clearQueryDefinition">
         <enabledWhen>
            <and>
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <or>
                     <equals
                           value="org.wcs.smart.query.SmartMultiCaQueryPerspective">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </or>
               </with>
               <with
                     variable="activeEditorId">
                  <or>
                     <equals
                           value="org.wcs.smart.query.ui.QueryResultsEditor">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.ui.SummaryEditor">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.ui.PatrolQueryResultsEditor">
