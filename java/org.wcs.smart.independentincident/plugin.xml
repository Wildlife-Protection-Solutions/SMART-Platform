<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            class="org.wcs.smart.incident.ui.IndIncidentListView"
            icon="images/icons/obj16/incident.png"
            id="org.wcs.smart.observation.ui.incidientView"
            name="%incidentlistview.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.observation.FieldDataPerspective">
         <view
               closeable="false"
               id="org.wcs.smart.observation.ui.incidientView"
               minimized="false"
               moveable="true"
               relationship="stack"
               relative="org.wcs.smart.fielddata.datafolder"
               showTitle="true"
               standalone="true"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.wcs.smart.observation.ObservationSource">
      <ObservationSource
            class="org.wcs.smart.incident.IndepedentIncidentSource">
      </ObservationSource>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.observation.ui.incidientView">
         <command
               commandId="org.wcs.smart.incident.delete"
               label="%delete.command.name"
               style="push"
               tooltip="%delete.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.incident.new"
               label="%newincident.command.name"
               style="push"
               tooltip="%newincident.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.independentincident.filter"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater">
         <menu
               icon="images/icons/obj16/incident.png"
               id="org.wcs.smart.menu.indient"
               label="%incident.menu.label"
               mnemonic="%incident.menu.mnemonic">
            <command
                  commandId="org.wcs.smart.incident.new"
                  mnemonic="%newincident.command.mnemonic"
                  style="push"
                  tooltip="%newincident.command.tooltip2">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.independentincident.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.independentincident.export"
                  mnemonic="%export.command.mnemonic"
                  style="push"
                  tooltip="%export.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.independentincident.import"
                  mnemonic="%import.command.mnemonic"
                  style="push"
                  tooltip="%import.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.independentincident.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.incident.perspective"
                  icon="images/icons/obj16/incident.png"
                  mnemonic="%incidentperspective.command.mnemonic"
                  style="push"
                  tooltip="%incidentperspective.command.tooltip">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="true"
            locationURI="popup:org.wcs.smart.observation.ui.incidientView">
         <command
               commandId="org.wcs.smart.incident.delete"
               mnemonic="%delete.command.mnemomic"
               style="push"
               tooltip="%delete.command.tooltip2">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?after=org.wcs.smart.perspective.fielddata">
         <command
               commandId="org.wcs.smart.incident.perspective"
               icon="images/icons/obj16/incident.png"
               mnemonic="%incidentperspective.command.mnemonic2"
               style="push"
               tooltip="%incidentperspective.command.tooltip2">
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.toolbar.create?before=org.wcs.smart.toolbar.create.data">
         <command
               commandId="org.wcs.smart.incident.new"
               label="%new.command.label2"
               style="push"
               tooltip="%new.command.tooltip2">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.incident.new"
            name="%new.command.name">
      </command>
      <command
            id="org.wcs.smart.incident.delete"
            name="%dekete.command.name">
      </command>
      <command
            id="org.wcs.smart.incident.perspective"
            name="%view.command.name">
      </command>
      <command
            id="org.wcs.smart.independentincident.filter"
            name="%filter.command.name">
      </command>
      <command
            id="org.wcs.smart.independentincident.export"
            name="%export.command">
      </command>
      <command
            id="org.wcs.smart.independentincident.import"
            name="%import.command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.incident.new"
            icon="images/icons/etool16/new_incident.png">
      </image>
      <image
            commandId="org.wcs.smart.incident.delete"
            icon="images/icons/etool16/delete_incident.png">
      </image>
      <image
            commandId="org.wcs.smart.independentincident.filter"
            icon="images/icons/etool16/filter_incident.png">
      </image>
      <image
            commandId="org.wcs.smart.independentincident.export"
            icon="images/icons/etool16/export_incident.png">
      </image>
      <image
            commandId="org.wcs.smart.independentincident.import"
            icon="images/icons/etool16/import_incident.png">
      </image>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.incident.ui.NewIncidentHandler"
            commandId="org.wcs.smart.incident.new">
         <activeWhen>
            <and>
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </and>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.DeleteIncidentHandler"
            commandId="org.wcs.smart.incident.delete">
         <activeWhen>
            <and>
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </and>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <instanceof
                        value="org.wcs.smart.incident.ui.IncidentEditorInput">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ViewIncidentHandler"
            commandId="org.wcs.smart.incident.perspective">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ShowIncidentFilterHandler"
            commandId="org.wcs.smart.independentincident.filter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ImportIncidentHandler"
            commandId="org.wcs.smart.independentincident.import">
         <activeWhen>
            <and>
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </and>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ExportIncidentHandler"
            commandId="org.wcs.smart.independentincident.export">
         <activeWhen>
            <and>
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </and>
         </activeWhen>
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.incident.ui.IncidentEditor"
            default="false"
            icon="images/icons/obj16/incident.png"
            id="org.wcs.smart.incident.ui.IncidentEditor"
            name="%editor.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.help.toc">
      <toc
            file="help/html/toc.xml"
            primary="true">
      </toc>
   </extension>

</plugin>
