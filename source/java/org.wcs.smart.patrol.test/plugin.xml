<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.patrol.generate.employee"
            name="Generate Employees">
      </command>
      <command
            id="org.wcs.smart.patrol.test.json"
            name="Test JSON Processors">
      </command>
      <command
            id="org.wcs.smart.patrol.test.json.connect"
            name="Test Connect JSON Processors">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?before=org.wcs.smart.fielddata">
         <menu
               id="org.wcs.smart.test"
               label="Testing Items">
            <command
                  commandId="org.wcs.smart.patrol.test.json"
                  label="Test JSON Processors"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.patrol.generate.employee"
                  label="Generate Employees"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.patrol.test.json.connect"
                  label="Test Connect JSON Processors"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.patrol.test.EmployeeCreatorHandler"
            commandId="org.wcs.smart.patrol.generate.employee">
      </handler>
      <handler
            class="org.wcs.smart.patrol.json.TestJsonHandler$TestJSonHandlerWrapper"
            commandId="org.wcs.smart.patrol.test.json">
      </handler>
      <handler
            class="org.wcs.smart.patrol.json.connecttest.ConnectTestJsonHandler$ConnectTestJsonHandlerWrapper"
            commandId="org.wcs.smart.patrol.test.json.connect">
      </handler>
   </extension>

</plugin>
