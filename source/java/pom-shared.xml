<?xml version="1.0" encoding="UTF-8"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	
	<modelVersion>4.0.0</modelVersion>
	
	<groupId>org.wcs.smart</groupId>
  	<artifactId>smart</artifactId>
  	<version>6.0.0-SNAPSHOT</version>
  	<packaging>pom</packaging>
  	
	<properties>
		<smart.version>6.0.0-SNAPSHOT</smart.version>
        	<geotools.version>11.2</geotools.version>
        	<jts.version>1.13</jts.version>
        	<hibernate.version>4.2.18.Final</hibernate.version>
        	<birt.version>4.4.1</birt.version>
        	<udig.version>2.0.0-SNAPSHOT</udig.version>
        	
        	<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    	</properties>
    
	<modules>
		<module>./org.wcs.smart/pom-shared.xml</module>
		<module>./org.wcs.smart.birt/pom-shared.xml</module>
		<module>./org.wcs.smart.dataentry/pom-shared.xml</module>
		<module>./org.wcs.smart.observation/pom-shared.xml</module>
		<module>./org.wcs.smart.query/pom-shared.xml</module>
		<module>./org.wcs.smart.report/pom-shared.xml</module>
		<module>./org.wcs.smart.patrol/pom-shared.xml</module>
		<module>./org.wcs.smart.patrol.query/pom-shared.xml</module>
		<module>./org.wcs.smart.observation.query/pom-shared.xml</module>
		<module>./org.wcs.smart.plan/pom-shared.xml</module>
		<module>./org.wcs.smart.intelligence/pom-shared.xml</module>
		<module>./org.wcs.smart.intelligence.query/pom-shared.xml</module>
		<module>./org.wcs.smart.independentincident/pom-shared.xml</module>
		<module>./org.wcs.smart.report.birt.query/pom-shared.xml</module>
		<module>./org.wcs.smart.birt.map/pom-shared.xml</module>
		<module>./org.wcs.smart.observation.query.report/pom-shared.xml</module>
		<module>./org.wcs.smart.patrol.query.report/pom-shared.xml</module>
		<module>./org.wcs.smart.intelligence.query.report/pom-shared.xml</module>
		<module>./org.wcs.smart.reporttable/pom-shared.xml</module>
		<module>../extensions/entity/org.wcs.smart.entity/pom-shared.xml</module>
		<module>../extensions/entity/org.wcs.smart.entity.query/pom-shared.xml</module>
		<module>../extensions/entity/org.wcs.smart.entity.query.report/pom-shared.xml</module>
		<module>../extensions/er/org.wcs.smart.er/pom-shared.xml</module>
		<module>../extensions/er/org.wcs.smart.er.query/pom-shared.xml</module>
		<module>../extensions/er/org.wcs.smart.er.query.report/pom-shared.xml</module>
		<module>../extensions/i2/org.wcs.smart.i2/pom-shared.xml</module>
		<module>../extensions/cybertracker/org.wcs.smart.cybertracker/pom-shared.xml</module>
		<module>../extensions/connect/org.wcs.smart.connect/pom-shared.xml</module>
		<module>../extensions/connect/org.wcs.smart.connect.dataqueue/pom-shared.xml</module>
		<module>../extensions/connect/org.wcs.smart.connect.cybertracker/pom-shared.xml</module>
		<module>../extensions/connect/org.wcs.smart.connect.dataqueue.cybertracker.patrol/pom-shared.xml</module>
		<module>../extensions/connect/org.wcs.smart.connect.dataqueue.cybertracker.survey/pom-shared.xml</module>
	</modules>
 
	<build>
		<sourceDirectory>shared</sourceDirectory>
		<resources>
			<resource>
        			<directory>.</directory>
        			<includes>
          				<include>plugin.xml</include>
        			</includes>
      			</resource>
      			<resource>
        			<directory>schema</directory>
        		</resource>
		</resources>
		<plugins>
      			<plugin>
        			<groupId>org.apache.maven.plugins</groupId>
        			<artifactId>maven-compiler-plugin</artifactId>
        			<version>3.3</version>
        			<configuration>
          				<source>1.8</source>
          				<target>1.8</target>
        			</configuration>
      			</plugin>
      			<plugin>
    				<groupId>org.apache.felix</groupId>
    				<artifactId>maven-bundle-plugin</artifactId>
    				<version>3.0.1</version>
    				<extensions>true</extensions>
				<!--<configuration><manifestLocation>META-INF</manifestLocation></configuration>-->
  			</plugin>
    		</plugins>
	</build>
	
	<repositories>
		<repository>
			<id>osgeo</id>
			<name>Open Source Geospatial Foundation Repository</name>
			<url>http://download.osgeo.org/webdav/geotools/</url>
		</repository>
    	</repositories>    
	
	<dependencies>
		<!-- javax.annotations -->
		<dependency>
		    <groupId>net.sourceforge.findbugs</groupId>
		    <artifactId>jsr305</artifactId>
		    <version>1.3.2</version>
		</dependency>
       		<dependency>
			<groupId>commons-io</groupId>
			<artifactId>commons-io</artifactId>
			<version>2.1</version>
		</dependency>
        	<dependency>
			<groupId>org.hibernate</groupId>
			<artifactId>hibernate-core</artifactId>
			<version>${hibernate.version}</version>
        	</dependency>
        	<dependency>
    			<groupId>com.vividsolutions</groupId>
    			<artifactId>jts</artifactId>
    			<version>${jts.version}</version>
			</dependency>
		<dependency>
            		<groupId>org.geotools</groupId>
            		<artifactId>gt-referencing</artifactId>
            		<version>${geotools.version}</version>
        	</dependency>
        	<dependency>
            		<groupId>org.geotools</groupId>
            		<artifactId>gt-api</artifactId>
            		<version>${geotools.version}</version>
        	</dependency>
	</dependencies>
</project>