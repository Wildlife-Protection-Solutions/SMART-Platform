<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.wcs.smart.observation.ObservationSource" name="Observation Source" schema="schema/org.wcs.smart.observation.ObservationSource.exsd"/>
   <extension-point id="org.wcs.smart.datalink.type" name="Data Link Type" schema="schema/org.wcs.smart.datalink.type.exsd"/>
   <extension
         point="org.wcs.smart.caDeleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.observation.internal.advisor.AttributeDMAdvisor"
            class="org.wcs.smart.ca.datamodel.Attribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.observation.internal.advisor.AttributeListItemDMAdvisor"
            class="org.wcs.smart.ca.datamodel.AttributeListItem">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.observation.internal.advisor.AttributeTreeNodeDMAdvisor"
            class="org.wcs.smart.ca.datamodel.AttributeTreeNode">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.observation.internal.advisor.CategoryDMAdvisor"
            class="org.wcs.smart.ca.datamodel.Category">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.observation.internal.advisor.CategoryAttributeDMAdvisor"
            class="org.wcs.smart.ca.datamodel.CategoryAttribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.observation.internal.advisor.EmployeeDeleteAdvisor"
            class="org.wcs.smart.ca.Employee">
      </DeleteAdvisor>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="true"
            class="org.wcs.smart.observation.ui.WaypointInfoView$WaypointInfoViewWrapper"
            icon="images/icons/view16/waypoint_info.png"
            id="org.wcs.smart.observation.waypointInfo"
            name="%waypointinfo.view.name">
      </view>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            class="org.wcs.smart.observation.model.Waypoint"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".observationGroup.waypoint.conservationArea"
            class="org.wcs.smart.observation.model.WaypointObservation"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".observation.observationGroup.waypoint.conservationArea"
            class="org.wcs.smart.observation.model.WaypointObservationAttribute"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".observation.observationGroup.waypoint.conservationArea"
            class="org.wcs.smart.observation.model.ObservationAttachment"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".waypoint.conservationArea"
            class="org.wcs.smart.observation.model.WaypointAttachment"
            supportsCcaa="false">
      </class>
      <class
            ca_uuid_property=".uuid"
            class="org.wcs.smart.observation.model.ObservationOptions"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".waypoint.conservationArea"
            class="org.wcs.smart.observation.model.WaypointObservationGroup"
            supportsCcaa="true">
      </class>
      <class
            ca_property=".id.observationAttribute.observation.observationGroup.waypoint.conservationArea"
            class="org.wcs.smart.observation.model.WaypointObservationAttributeList"
            supportsCcaa="true">
      </class>
      <class
            class="org.wcs.smart.observation.model.DataLink"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".tag.conservationArea"
            class="org.wcs.smart.observation.model.AttachmentTagLink"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.menu.ca">
         <menu
               id="org.wcs.smart.fielddata"
               label="%fielddata.menu.label"
               mnemonic="%fielddata.menu.mnemonic"
               tooltip="%fielddata.menu.tooltip">
            <separator
                  name="org.wcs.smart.fielddata.dataseparater"
                  visible="true">
            </separator>
            <separator
                  name="org.wcs.smart.fielddata.dataseparater2"
                  visible="false">
            </separator>
            <command
                  commandId="org.wcs.smart.observation.options"
                  style="push">
               <visibleWhen
                     checkEnabled="true">
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.imageprocessor.resize"
                  style="push">
               <visibleWhen
                     checkEnabled="false">
                  <and>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                     </or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                  </and>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.fielddata.dataseparater4"
                  visible="true">
            </separator>
            <command
                  commandId="org.eclipse.ui.perspectives.showPerspective"
                  icon="images/icons/view16/fielddata.png"
                  label="%fielddata.perspective.command.label"
                  mnemonic="%fielddata.perspective.command.mnemonic"
                  style="push">
               <parameter
                     name="org.eclipse.ui.perspectives.showPerspective.perspectiveId"
                     value="org.wcs.smart.observation.FieldDataPerspective">
               </parameter>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="analyst">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </and>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?after=org.wcs.smart.perspectivesSeperator">
         <separator
               name="org.wcs.smart.perspective.fielddata"
               visible="false">
         </separator>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.file?before=org.wcs.menu.file.changeuserpassword">
         <separator
               name="org.wcs.smart.query.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.eclipse.ui.file.export"
               id="x"
               label="%file.exportmap.command.label"
               style="push"
               tooltip="%file.exportmap.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.observation.FieldDataPerspective">
                     </equals>
                  </with>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator3"
               visible="true">
         </separator>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.observation.waypointInfo">
         <command
               commandId="org.wcs.smart.observation.waypointinfoview.images.toggle"
               icon="images/icons/obj16/hide_images.png"
               label="%command.toggleattachments.label"
               style="toggle"
               tooltip="%command.toggleattachments.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.observation.waypointinfoview.text.toggle"
               icon="images/icons/obj16/hide_text.png"
               label="%command.toggletext.label"
               style="toggle"
               tooltip="%command.toggletext.tooltip">
         </command>
         <separator
               name="org.wcs.smart.observation.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.observation.waypointinfoview.refresh"
               icon="platform:/plugin/org.wcs.smart/images/icons/shared16/refresh.png"
               label="%refresh.command.label"
               style="push"
               tooltip="%refresh.command.tooltip">
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.observation.ui.FieldDataPerspective"
            id="org.wcs.smart.observation.FieldDataPerspective"
            name="%fielddata.perspective.name">
      </perspective>
   </extension>
   <extension
         point="org.wcs.smart.caTemplateCloner">
      <templateCloner
            class="org.wcs.smart.observation.ObservationCloner"
            id="org.wcs.smart.observation.cloner">
         <require
               id="org.wcs.smart.conservationAreaCloner">
         </require>
      </templateCloner>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.observation.options"
            name="%fielddataops.command.name">
      </command>
      <command
            id="org.wcs.smart.observation.perspective.show"
            name="%showperspective.command.name">
         <commandParameter
               id="org.wcs.smart.observation.perspective.show.focusview"
               name="%commandParameter.name"
               optional="true">
         </commandParameter>
      </command>
      <command
            id="org.wcs.smart.observation.waypointinfoview.images.toggle"
            name="%command.toggleimages.name">
         <state
               class="org.eclipse.ui.handlers.RegistryToggleState:false"
               id="org.eclipse.ui.commands.toggleState">
         </state>
      </command>
            <command
            id="org.wcs.smart.observation.waypointinfoview.text.toggle"
            name="%command.toggletext.name">
               <state
                     class="org.eclipse.ui.handlers.RegistryToggleState:false"
                     id="org.eclipse.ui.commands.toggleState">
               </state>
      </command>
            <command
                  id="org.wcs.smart.observation.waypointinfoview.refresh"
                  name="%refresh.command.name">
            </command>
            <command
                  id="org.wcs.smart.observation.import.json"
                  name="%command.name.importjson">
            </command>
            <command
                  id="org.wcs.smart.imageprocessor.resize"
                  name="Resize Images...">
            </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.observation.ui.ShowOptionsHandler$ShowOptionsHandlerWrapper"
            commandId="org.wcs.smart.observation.options">
         <activeWhen>
            <and>
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </and>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.observation.ui.WpInfoViewToggleImagesHandler$WpInfoViewToggleImagesHandlerWrapper"
            commandId="org.wcs.smart.observation.waypointinfoview.images.toggle">
      </handler>
      <handler
            class="org.wcs.smart.observation.ui.WpInfoViewToggleTextHandler$WpInfoViewToggleTextHandlerWrapper"
            commandId="org.wcs.smart.observation.waypointinfoview.text.toggle">
      </handler>
      <handler
            class="org.wcs.smart.observation.ui.ShowFieldDataPerspective$ShowFieldDataPerspectiveWrapper"
            commandId="org.wcs.smart.observation.perspective.show">
      </handler>
      <handler
            class="org.wcs.smart.observation.ui.WpInfoViewRefreshHandler$WpInfoViewRefreshHandlerWrapper"
            commandId="org.wcs.smart.observation.waypointinfoview.refresh">
      </handler>
      <handler
            class="org.wcs.smart.observation.ui.ImportJsonDataHandler$ImportJsonDataHandlerWrapper"
            commandId="org.wcs.smart.observation.import.json">
      </handler>
      <handler
            class="org.wcs.smart.imageprocessor.ui.ShowResizeHandler$ShowResizeHandlerWrapper"
            commandId="org.wcs.smart.imageprocessor.resize">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.caFilestoreDir">
      <FilestoreDirectory
            directory="incidents">
      </FilestoreDirectory>
   </extension>
   <extension
         point="org.eclipse.core.runtime.adapters">
      <factory
            adaptableType="org.wcs.smart.observation.udig.WaypointSimpleFeature"
            class="org.wcs.smart.observation.udig.WaypointSimpleFeatureAdapterFactory">
         <adapter
               type="org.wcs.smart.observation.model.Waypoint">
         </adapter>
      </factory>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.interceptor">
      <integrator
            class="org.wcs.smart.observation.WaypointHibernateIntegrator">
      </integrator>
   </extension>
   <extension
         point="org.eclipse.core.expressions.propertyTesters">
      <propertyTester
            class="org.wcs.smart.observation.FocusViewTester"
            id="org.wcs.smart.fielddata.focusview"
            namespace="org.wcs.smart.fielddata"
            properties="focusview"
            type="java.lang.Object">
      </propertyTester>
   </extension>
   <extension
         point="org.wcs.smart.datalink.type">
      <type
            hibernate_class="WaypointObservationGroup"
            type_key="obsgroup">
      </type>
      <type
            hibernate_class="WaypointObservation"
            type_key="observation">
      </type>
   </extension>

</plugin>
