   <category-def name="intelligence" label="SMART Intelligence Plug-in">
      <description>
         The SMART Intelligence plug-in contains the choice of two intelligence modules that allows users to organize, maintain and query intelligence information. Intelligence information may have been gathered by earlier patrols, or may have been received from external sources. Intelligence information may be useful to Conservation Area managers when they plan future patrols.
      </description>
   </category-def>
   <category-def name="planning" label="SMART Planning Plug-in">
      <description>
         The SMART Planning plug-in contains a plan module that allows users to organize, maintain and query planning information. Plans allow for a set of targets (such as total distance patrolled or specific locations to visit) to be assigned to a patrol or series of patrols.
      </description>
   </category-def>
   <category-def name="independentincident" label="SMART Independent Incident Plug-in">
      <description>
         The SMART Independent Incident plug-in provides the ability to record observations (using the data model) that are not associated with a patrol (or any other data collection object within SMART).
      </description>
   </category-def>
   <category-def name="entity" label="SMART Entity Tracking Plug-in">
      <description>
         The SMART Entity Tracking plug-in provides the ability to record and track specific entities that move (such as individual animals) or fixed entities (such as a gate or bridge), record their attributes, and record observations associated with the entities.
      </description>
   </category-def>
   <category-def name="ecologicalrecords" label="SMART Ecological Records Plug-in">
      <description>
         The SMART Ecological Records (SMART-ER) plug-in extends the SMART capability to more scientific data collection and analysis of species, their habitats and disturbances. The Ecological Records plug-in is used for recording and analysing field survey data.
      </description>
   </category-def>
   <category-def name="connect" label="SMART Connect">
      <description>
         The SMART Connect plug-in allows SMART Desktop software to communicate and share data over the Internet with a SMART Connect Server.
      </description>
   </category-def>
   <category-def name="cybertracker" label="SMART Cybertracker">
      <description>
         The SMART CyberTracker (SMART-CT) plug-in provides compatibility with the CyberTracker application - which itself runs on a GPS-enabled handheld device. Using this plug-in, SMART users are able to create and deploy CyberTracker applications based on the Data Model or a Configurable Model (a simplified data model for the CyberTracker application). The plug-in also provides the ability to work directly with handheld devices while exporting/importing data, doing all of the interaction with CyberTracker in the background.
      </description>
   </category-def>
   <category-def name="connectdq" label="SMART Connect Data Queue">
      <description>
         The SMART Connect Data Queue plug-in allows SMART Desktop software to processes data files uploaded to a SMART Connect Server.
      </description>
   </category-def>
   <category-def name="languagepacks" label="SMART Application Language Packs">
      <description>
         SMART Application Language Packs
      </description>
   </category-def>
</site>
