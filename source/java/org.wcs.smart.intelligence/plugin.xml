<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu">
         <menu
               id="org.wcs.smart.intelligence.menu"
               label="%menu.create.label">
            <command
                  commandId="org.wcs.smart.intelligence.NewIntelligence"
                  label="%command.create.label"
                  style="push">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.intelligence.export"
                  label="%export.command.label"
                  style="push"
                  tooltip="%export.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.intelligence.import"
                  label="%import.command.label"
                  style="push"
                  tooltip="%import.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.intelligence.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.intelligence.EditIntelligenceSources"
                  label="%sourceedit.command.label"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.intelligence.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.intelligence.ShowIntelligencePersepctive"
                  label="%view.command.label"
                  style="push"
                  tooltip="%command.perspective.tooltip">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?endof=org.wcs.smart.perspectivesSeperator">
         <command
               commandId="org.wcs.smart.intelligence.ShowIntelligencePersepctive"
               label="%command.perspective.label"
               style="push"
               tooltip="%command.perspective.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.intelligence.IntelligenceListView">
         <command
               commandId="org.wcs.smart.intelligence.DeleteIntelligence"
               icon="images/etool16/delete.png"
               label="%command.delete.label"
               style="push"
               tooltip="%command.delete.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.intelligence.NewIntelligence"
               label="%command.create.label"
               style="push"
               tooltip="%command.create.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.intelligence.ShowIntelligenceFilter"
               icon="images/etool16/filter.png"
               label="%command.filter.label"
               style="push"
               tooltip="%command.filter.tooltip">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="true"
            locationURI="popup:org.wcs.smart.intelligence.IntelligenceListView">
         <command
               commandId="org.wcs.smart.intelligence.translate"
               label="%translate.command.label"
               style="push"
               tooltip="%translate.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.intelligence.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.intelligence.DeleteIntelligence"
               icon="images/etool16/delete.png"
               label="%delete.command.label"
               style="push"
               tooltip="%delete.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.file?before=org.wcs.menu.file.changeuserpassword">
         <separator
               name="org.wcs.smart.intelligence.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.eclipse.ui.file.export"
               label="%exportmap.command.label"
               mnemonic="%exportmap.command.mnemonic"
               style="push"
               tooltip="%exportmap.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.intelligence.IntelligencePerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.intelligence.separator3"
               visible="true">
         </separator>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.intelligence.NewIntelligence"
            name="%command.create.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.ShowIntelligencePersepctive"
            name="%command.perspective.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.DeleteIntelligence"
            name="%command.delete.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.ShowIntelligenceFilter"
            name="%command.filter.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.translate"
            name="%translate.command.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.export"
            name="%export.command.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.import"
            name="%import.command.name">
      </command>
      <command
            id="org.wcs.smart.intelligence.EditIntelligenceSources"
            name="%sourceedit.command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.NewIntelligenceHandler"
            commandId="org.wcs.smart.intelligence.NewIntelligence">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.ShowIntelligencePersepctiveHandler"
            commandId="org.wcs.smart.intelligence.ShowIntelligencePersepctive">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.DeleteIntelligenceHandler"
            commandId="org.wcs.smart.intelligence.DeleteIntelligence">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.ShowIntelligenceFilterHandler"
            commandId="org.wcs.smart.intelligence.ShowIntelligenceFilter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.TranslateIntelligenceHandler"
            commandId="org.wcs.smart.intelligence.translate">
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.ExportIntelligenceHandler"
            commandId="org.wcs.smart.intelligence.export">
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.ImportIntelligenceHandler"
            commandId="org.wcs.smart.intelligence.import">
      </handler>
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.EditIntelligenceSourceHandler"
            commandId="org.wcs.smart.intelligence.EditIntelligenceSources">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.intelligence.model.Intelligence">
      </class>
      <class
            ca_property=".intelligence.conservationArea"
            class="org.wcs.smart.intelligence.model.IntelligencePoint">
      </class>
      <class
            ca_property=".intelligence.conservationArea"
            class="org.wcs.smart.intelligence.model.IntelligenceAttachment">
      </class>
      <class
            ca_property=".id.patrol.conservationArea"
            class="org.wcs.smart.intelligence.model.PatrolIntelligence">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.intelligence.ui.IntelligencePerspective"
            icon="images/etool16/intelligence.png"
            id="org.wcs.smart.intelligence.IntelligencePerspective"
            name="%perspective.name">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.intelligence.ui.IntelligenceListView"
            icon="images/etool16/intelligence.png"
            id="org.wcs.smart.intelligence.IntelligenceListView"
            name="%view.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.intelligence.ui.editor.IntelligenceEditor"
            default="false"
            icon="images/etool16/intelligence.png"
            id="org.wcs.smart.intelligence.IntelligenceEditor"
            matchingStrategy="org.wcs.smart.intelligence.ui.editor.IntelligenceEditorMatchingStrategy"
            name="%editor.name">
      </editor>
   </extension>
   <extension
         point="org.wcs.smart.patrol.editorContribution">
      <contribution
            class="org.wcs.smart.intelligence.ui.patrol.ReportedIntelligenceContribution">
      </contribution>
      <contribution
            class="org.wcs.smart.intelligence.ui.patrol.MotivationIntelligenceContribution">
      </contribution>
   </extension>
   <extension
         point="org.wcs.smart.patrol.wizardpage">
      <wizardpage
            class="org.wcs.smart.intelligence.ui.patrol.IntelligencePatrolWizardPage"
            id="newpatrol.intelligence"
            location="after=newpatrol.patrolid">
      </wizardpage>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.intelligence.NewIntelligence"
            icon="images/etool16/intelligence_add.png">
      </image>
      <image
            commandId="org.wcs.smart.intelligence.ShowIntelligencePersepctive"
            icon="images/etool16/intelligence.png">
      </image>
      <image
            commandId="org.wcs.smart.intelligence.export"
            icon="images/etool16/import_intel.png">
      </image>
      <image
            commandId="org.wcs.smart.intelligence.import"
            icon="images/etool16/export_intel.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.patrol.query.filter.patrol">
      <contribution
            class="org.wcs.smart.intelligence.query.IntelligenceQueryFilterPatrolContribution">
      </contribution>
   </extension>
   <extension
         point="org.wcs.smart.patrol.xml">
      <contribution
            class="org.wcs.smart.intelligence.xml.patrol.PatrolXmlExtraDataContribution">
      </contribution>
   </extension>

</plugin>
