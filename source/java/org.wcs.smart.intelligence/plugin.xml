<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.plan.menu">
         <menu
               id="org.wcs.smart.intelligence.menu"
               label="%intelligence.menu.label">
            <command
                  commandId="org.wcs.smart.intelligence.NewIntelligence"
                  label="%intelligence.command.label"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.intelligence.NewIntelligence"
            name="%intelligence.command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.intelligence.ui.handlers.NewIntelligenceHandler"
            commandId="org.wcs.smart.intelligence.NewIntelligence">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.intelligence.model.Intelligence">
      </class>
      <class
            ca_property=".intelligence.conservationArea"
            class="org.wcs.smart.intelligence.model.IntelligencePoint">
      </class>
      <class
            ca_property=".intelligence.conservationArea"
            class="org.wcs.smart.intelligence.model.IntelligenceAttachment">
      </class>
   </extension>

</plugin>
