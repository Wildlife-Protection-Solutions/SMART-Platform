      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.intelligence.ui.IntelligenceListView$IntelligenceListViewWrapper"
            icon="images/etool16/intelligence.png"
            id="org.wcs.smart.intelligence.IntelligenceListView"
            name="%view.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
