      <QueryTypeDataset
            class="org.wcs.smart.report.query.data.oda.query.PatrolSmartQuery"
            queryTypeKey="patrolquery">
      </QueryTypeDataset>
      <QueryTypeDataset
            class="org.wcs.smart.report.query.data.oda.query.PatrolSmartQuery"
            queryTypeKey="patrolsummary">
      </QueryTypeDataset>
      <QueryTypeDataset
            class="org.wcs.smart.report.query.data.oda.query.PatrolSmartQuery"
            queryTypeKey="patrolwaypoint">
      </QueryTypeDataset>
   </extension>
   <extension
         point="org.eclipse.ui.startup">
      <startup
            class="org.wcs.smart.report.query.DummyStartUp">
      </startup>
   </extension>

