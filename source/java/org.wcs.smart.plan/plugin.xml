<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.report">
         <menu
               id="org.wcs.smart.plan.menu"
               label="%plan.menu.label"
               mnemonic="%plan.menu.mnemonic">
            <command
                  commandId="org.wcs.smart.plan.NewPlan"
                  icon="images/icons/view16/plan_add.png"
                  label="%plan.menu.command.label.newplan"
                  mnemonic="%plan.menu.command.mnemonic.newplan"
                  style="push"
                  tooltip="%plan.menu.command.tooltip.newplan">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <menu
                  label="Plan Template">
               <command
                     commandId="org.wcs.smart.plan.editTemplate"
                     style="push"
                     tooltip="Edit the plan print template">
               </command>
               <command
                     commandId="org.wcs.smart.plan.revertTemplate"
                     style="push"
                     tooltip="Reverts the plan template to the default">
               </command>
               <visibleWhen
                     checkEnabled="false">
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </menu>
            <separator
                  name="org.wcs.smart.plan.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.plan.ShowPlanPerspective"
                  icon="images/icons/view16/plan.png"
                  label="%plan.menu.command.label.viewplans"
                  style="push"
                  tooltip="%plan.menu.command.tooltip.viewplans">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?before=org.wcs.smart.intelligence.ShowIntelligencePersepctive">
         <command
               commandId="org.wcs.smart.plan.ShowPlanPerspective"
               icon="images/icons/view16/plan.png"
               label="%smart.toolbar.command.label.viewplans"
               style="push"
               tooltip="%smart.toolbar.command.tooltip.viewplans">
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </command>
      </menuContribution>

      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.plan.PlanListView">
         <command
               commandId="org.wcs.smart.plan.DeletePlan"
               icon="images/icons/etool16/delete.png"
               label="%planlistview.toolbar.command.label.deleteplan"
               style="push"
               tooltip="%planlistview.toolbar.command.tooltip.deleteplan">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.plan.NewPlan"
               icon="images/icons/view16/plan_add.png"
               label="%planlistview.toolbar.command.label.newplan"
               style="push"
               tooltip="%planlistview.toolbar.command.tooltip.newplan">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.plan.ShowPlanFilter"
               style="push"
               tooltip="%filterplan.command.tooltip">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:org.wcs.smart.plan.PlanListView">
         <command
               commandId="org.wcs.smart.plan.translate"
               label="%translate.command.label"
               style="push"
               tooltip="%translate.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
               </or>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.plan.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.plan.exportPdf"
               style="push"
               tooltip="Exports the selected plan to a pdf file for printing">
         </command>
         <separator
               name="org.wcs.smart.plan.separator3"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.plan.DeletePlan"
               icon="images/icons/etool16/delete.png"
               label="%planlistview.popup.command.label.deleteplan2"
               style="push"
               tooltip="%planlistview.popup.command.tooltip.deleteplan2">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="org.wcs.smart.plan.toolbar">
            <command
                  commandId="org.wcs.smart.plan.exportPdfEditor"
                  style="push">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.plan.planPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.eclipse.ui.file.save"
                  style="push">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.plan.PlanReportPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.file?before=org.wcs.menu.file.changeuserpassword">
         <command
               commandId="org.wcs.smart.plan.exportPdfEditor"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.plan.planPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.eclipse.ui.file.save"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.plan.PlanReportPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.plan.ui.handlers.NewPlanHandler"
            commandId="org.wcs.smart.plan.NewPlan">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ShowPlanPersepctiveHandler"
            commandId="org.wcs.smart.plan.ShowPlanPerspective">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ShowPlanFilter"
            commandId="org.wcs.smart.plan.ShowPlanFilter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.DeletePlanHandler"
            commandId="org.wcs.smart.plan.DeletePlan">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.TranslatePlanHandler"
            commandId="org.wcs.smart.plan.translate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.RevertPlanTemplate"
            commandId="org.wcs.smart.plan.revertTemplate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.EditPlanTemplate"
            commandId="org.wcs.smart.plan.editTemplate">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ExportPlanPdf"
            commandId="org.wcs.smart.plan.exportPdf">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate>
                  <instanceof
                        value="org.wcs.smart.plan.ui.editor.PlanEditorInput">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.plan.ui.handlers.ExportPlanPdf"
            commandId="org.wcs.smart.plan.exportPdfEditor">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="activeEditorId">
               <equals
                     value="org.wcs.smart.plan.ui.editor.PlanEditor">
               </equals>
            </with>
         </enabledWhen>
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.plan.NewPlan"
            name="%command.label.newplan2">
      </command>
      <command
            id="org.wcs.smart.plan.ShowPlanPerspective"
            name="%command.name.showplans">
      </command>
      <command
            id="org.wcs.smart.plan.ShowPlanFilter"
            name="%command.name.showfilter">
      </command>
      <command
            id="org.wcs.smart.plan.DeletePlan"
            name="%command.name.deleteplan">
      </command>
      <command
            id="org.wcs.smart.plan.translate"
            name="%translate.command.name">
      </command>
      <command
            id="org.wcs.smart.plan.exportPdf"
            name="Export To PDF">
      </command>
      <command
            id="org.wcs.smart.plan.exportPdfEditor"
            name="Export To PDF">
      </command>
      <command
            id="org.wcs.smart.plan.revertTemplate"
            name="Revert to Default Template">
      </command>
      <command
            id="org.wcs.smart.plan.editTemplate"
            name="Edit Plan Template">
      </command>
   </extension>

   <extension
         point="org.wcs.smart.patrol.wizardpage">
      <wizardpage
            class="org.wcs.smart.plan.internal.ui.patrol.NewPatrolPlanWizardPage"
            id="newpatrol.plan"
            location="after=newpatrol.patrolid">
      </wizardpage>
   </extension>

   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.plan.model.Plan">
      </class>
      <class
            ca_property=".plan.conservationArea"
            class="org.wcs.smart.plan.model.NumericPlanTarget">
      </class>
      <class
            ca_property=".plan.conservationArea"
            class="org.wcs.smart.plan.model.AdministrativePlanTarget">
      </class>
      <class
            ca_property=".id.plan.conservationArea"
            class="org.wcs.smart.plan.model.PatrolPlan">
      </class>
      <class
            ca_property=".plan.conservationArea"
            class="org.wcs.smart.plan.model.SpatialPlanTarget">
      </class>
      <class
            ca_property=".planTarget.plan.conservationArea"
            class="org.wcs.smart.plan.model.SpatialPlanTargetPoint">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.patrol.editorContribution">
      <contribution
            class="org.wcs.smart.plan.internal.ui.patrol.PatrolPlanContribution">
      </contribution>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.plan.ui.perspective.PlanPerspective"
            id="org.wcs.smart.plan.planPerspective"
            name="%plan.perspective.name">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.plan.ui.perspective.PlanListView"
            icon="images/icons/view16/plan.png"
            id="org.wcs.smart.plan.PlanListView"
            name="%planlistview.view.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.plan.ui.editor.PlanEditor"
            default="false"
            icon="images/icons/view16/plan.png"
            id="org.wcs.smart.plan.ui.editor.PlanEditor"
            name="%planlistview.editor.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.plan.ShowPlanFilter"
            icon="images/icons/etool16/plan_filter.png">
      </image>
      <image
            commandId="org.wcs.smart.plan.DeletePlan"
            icon="images/icons/etool16/delete.png">
      </image>
      <image
            commandId="org.wcs.smart.plan.exportPdf"
            icon="images/icons/etool16/printpdf.png">
      </image>
      <image
            commandId="org.wcs.smart.plan.exportPdfEditor"
            icon="images/icons/etool16/printpdf.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.query.filter.patrol">
      <contribution
            class="org.wcs.smart.plan.query.PlanQueryFilterPatrolContribution">
      </contribution>
   </extension>
   <extension
         point="org.wcs.smart.patrol.xml">
      <contribution
            class="org.wcs.smart.plan.xml.patrol.PatrolPlanXmlExtraDataContribution">
      </contribution>
   </extension>
   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            class="org.wcs.smart.plan.internal.preference.PlanConfigurationPreferencePage"
            id="org.wcs.smart.preference.PlanConfiguration"
            name="%planconfig.preferencepage.name">
      </page>
   </extension>
   <extension
         point="org.wcs.smart.ca.deleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.plan.advisors.StationDeleteAdvisor"
            class="org.wcs.smart.ca.Station">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.plan.advisors.TeamDeleteAdvisor"
            class="org.wcs.smart.patrol.model.Team">
      </DeleteAdvisor>
   </extension>
   <extension
         point="org.wcs.smart.birt.reportEditorManager">
      <EditorManager
            EditorInput="org.wcs.smart.plan.report.ReportPlanEditorInput"
            EditorManager="org.wcs.smart.plan.report.ReportPlanManager">
      </EditorManager>
   </extension>
   <extension
         point="org.eclipse.datatools.connectivity.oda.dataSource">
      <dataSource
            defaultDisplayName="SMART Plan Data Source"
            driverClass="org.wcs.smart.plan.report.oda.SmartPlanDriver"
            id="org.wcs.smart.plan.report.oda.SmartPlanDriver"
            odaVersion="3.0"
            overrideExplorerFiltering="false"
            setThreadContextClassLoader="false">
      </dataSource>
      <dataSet
            defaultDisplayName="SMART Plan Targets"
            id="org.wcs.smart.plan.report.oda.SmartPlanTargets">
         <dataTypeMapping
               nativeDataType="Boolean"
               nativeDataTypeCode="16"
               odaScalarDataType="Boolean">
         </dataTypeMapping>
        <dataTypeMapping
               nativeDataType="String"
               nativeDataTypeCode="12"
               odaScalarDataType="String">
         </dataTypeMapping>
         <dataTypeMapping
               nativeDataType="Integer"
               nativeDataTypeCode="4"
               odaScalarDataType="Integer">
         </dataTypeMapping>
         <dataTypeMapping
               nativeDataType="Double"
               nativeDataTypeCode="8"
               odaScalarDataType="Double">
         </dataTypeMapping>
         <dataTypeMapping
               nativeDataType="BigDecimal"
               nativeDataTypeCode="3"
               odaScalarDataType="Decimal">
         </dataTypeMapping>
         <dataTypeMapping
               nativeDataType="Date"
               nativeDataTypeCode="91"
               odaScalarDataType="Date">
         </dataTypeMapping>
         <dataTypeMapping
               nativeDataType="Time"
               nativeDataTypeCode="92"
               odaScalarDataType="Time">
         </dataTypeMapping>
         <dataTypeMapping
               nativeDataType="Timestamp"
               nativeDataTypeCode="93"
               odaScalarDataType="Timestamp">
         </dataTypeMapping>
      </dataSet>
   </extension>
   <extension
         point="org.eclipse.datatools.connectivity.oda.design.ui.dataSource">
      <dataSourceUI
            id="org.wcs.smart.plan.report.oda.SmartPlanDriver">
         <newDataSourceWizard
               includesProgressMonitor="true"
               pageClass="org.wcs.smart.plan.report.oda.ui.SmartPlanDataSourceWizardPage"
               windowTitle="SMART Plan Data Source">
         </newDataSourceWizard>
      </dataSourceUI>
      <dataSetUI
            id="org.wcs.smart.plan.report.oda.SmartPlanTargets"
            initialPageId="org.wcs.smart.plan.report.smartPlanTargets.page1"
            supportsInParameters="true"
            supportsOutParameters="false">
         <dataSetWizard
               class="org.eclipse.datatools.connectivity.oda.design.ui.wizards.DataSetWizard"
               windowTitle="Smart Plan Targets"></dataSetWizard>
         <dataSetPage
               displayName="SMART Plan Targets"
               id="org.wcs.smart.plan.report.smartPlanTargets.page1"
               path="/"
               wizardPageClass="org.wcs.smart.plan.report.oda.ui.SmartPlanTargetDatasetWizardPage">
         </dataSetPage>
      </dataSetUI>
   </extension>

</plugin>
