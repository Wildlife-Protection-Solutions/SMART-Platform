      <appinfo>
         <meta.schema plugin="org.wcs.smart.report.birt.map" id="org.wcs.smart.report.birt.maplayer" name="Map Layer"/>
      </appinfo>
      <documentation>
         Provides additional layers that can be added to SMART BIRT maps.
      </documentation>
   </annotation>

   <element name="extension">
      <annotation>
         <appinfo>
            <meta.element />
         </appinfo>
      </annotation>
      <complexType>
         <sequence minOccurs="1" maxOccurs="unbounded">
            <element ref="MapLayer"/>
            <element ref="StyleProvider"/>
         </sequence>
         <attribute name="point" type="string" use="required">
            <annotation>
               <documentation>
                  
               </documentation>
            </annotation>
         </attribute>
         <attribute name="id" type="string">
            <annotation>
               <documentation>
                  
               </documentation>
            </annotation>
