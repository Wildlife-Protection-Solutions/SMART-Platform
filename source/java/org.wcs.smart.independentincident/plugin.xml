<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            class="org.wcs.smart.incident.ui.IndIncidentListView$IndIncidentListViewWrapper"
            icon="images/icons/obj16/incident.png"
            id="org.wcs.smart.observation.ui.incidientView"
            name="%incidentlistview.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.observation.FieldDataPerspective">
         <view
               closeable="false"
               id="org.wcs.smart.observation.ui.incidientView"
               minimized="false"
               moveable="true"
               relationship="stack"
               relative="org.wcs.smart.fielddata.datafolder"
               showTitle="true"
               standalone="true"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.wcs.smart.observation.ObservationSource">
      <ObservationSource
            class="org.wcs.smart.incident.IndepedentIncidentSource"
            ui_provider="org.wcs.smart.incident.ui.IndIncidentSourceUiProvider">
      </ObservationSource>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.observation.ui.incidientView">
         <command
               commandId="org.wcs.smart.incident.delete"
               label="%delete.command.name"
               style="push"
               tooltip="%delete.command.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.incident.new"
               label="%newincident.command.name"
               style="push"
               tooltip="%newincident.command.tooltip">
         </command>
         <command
               commandId="org.wcs.smart.independentincident.filter"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater">
         <menu
               icon="images/icons/obj16/incident.png"
               id="org.wcs.smart.menu.indient"
               label="%incident.menu.label"
               mnemonic="%incident.menu.mnemonic">
            <command
                  commandId="org.wcs.smart.incident.new"
                  icon="images/icons/etool16/add_incident.png"
                  mnemonic="%newincident.command.mnemonic"
                  style="push"
                  tooltip="%newincident.command.tooltip2">
            </command>
            <separator
                  name="org.wcs.smart.independentincident.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.independentincident.export"
                  mnemonic="%export.command.mnemonic"
                  style="push"
                  tooltip="%export.command.tooltip">
            </command>
            <command
                  commandId="org.wcs.smart.independentincident.import"
                  mnemonic="%import.command.mnemonic"
                  style="push"
                  tooltip="%import.command.tooltip">
            </command>
            <separator
                  name="org.wcs.smart.independentincident.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.observation.perspective.show"
                  icon="images/icons/obj16/incident.png"
                  label="%view.command.name"
                  mnemonic="%incidentperspective.command.mnemonic"
                  style="push"
                  tooltip="%incidentperspective.command.tooltip">
               <parameter
                     name="org.wcs.smart.observation.perspective.show.focusview"
                     value="org.wcs.smart.observation.ui.incidientView">
               </parameter>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="analyst">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </and>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="true"
            locationURI="popup:org.wcs.smart.observation.ui.incidientView">
         <command
               commandId="org.wcs.smart.incident.open"
               style="push">
         </command>
         <command
               commandId="org.wcs.smart.incident.new"
               style="push">
         </command>
         <separator
               name="org.wcs.smart.independentincident.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.incident.delete"
               mnemonic="%delete.command.mnemomic"
               style="push"
               tooltip="%delete.command.tooltip2">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?after=org.wcs.smart.perspective.fielddata">
         <command
               commandId="org.wcs.smart.observation.perspective.show"
               icon="images/icons/obj16/incident.png"
               label="%incidentperspective.command.label"
               mnemonic="%incidentperspective.command.mnemonic2"
               mode="FORCE_TEXT"
               style="radio"
               tooltip="%incidentperspective.command.tooltip">
            <parameter
                  name="org.wcs.smart.observation.perspective.show.focusview"
                  value="org.wcs.smart.observation.ui.incidientView">
            </parameter>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="analyst">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.toolbar.create?before=org.wcs.smart.toolbar.create.data">
         <command
               commandId="org.wcs.smart.incident.new"
               label="%new.command.label2"
               style="push"
               tooltip="%new.command.tooltip2">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="analyst">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="vertical.org.wcs.smart.incident.toolbar1">
            <command
                  commandId="org.wcs.smart.incident.new"
                  icon="images/icons/etool16/add_incident.png"
                  label="New"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%newincident.command.tooltip2">
               <visibleWhen>
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.observation.ui.incidientView">
                     </test>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="analyst">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
         <toolbar
               id="vertical.org.wcs.smart.incident.toolbar2">
            <command
                  commandId="org.wcs.smart.independentincident.import"
                  label="Import"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%import.command.tooltip">
               <visibleWhen>
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.observation.ui.incidientView">
                     </test>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="analyst">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.independentincident.export"
                  label="Export"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%export.command.tooltip">
               <visibleWhen>
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.observation.ui.incidientView">
                     </test>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="analyst">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.incident.new"
            name="%command.newincident.name">
      </command>
      <command
            id="org.wcs.smart.incident.delete"
            name="%command.deleteincident.name">
      </command>
      <command
            id="org.wcs.smart.independentincident.filter"
            name="%filter.command.name">
      </command>
      <command
            id="org.wcs.smart.independentincident.export"
            name="%export.command">
      </command>
      <command
            id="org.wcs.smart.independentincident.import"
            name="%import.command.name">
      </command>
      <command
            id="org.wcs.smart.incident.open"
            name="%command.openincident.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.incident.new"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/add.png">
      </image>
      <image
            commandId="org.wcs.smart.incident.delete"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/delete.png">
      </image>
      <image
            commandId="org.wcs.smart.independentincident.filter"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/filter.png">
      </image>
      <image
            commandId="org.wcs.smart.independentincident.export"
            icon="images/icons/etool16/export_incident.png">
      </image>
      <image
            commandId="org.wcs.smart.independentincident.import"
            icon="images/icons/etool16/import_incident.png">
      </image>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.incident.ui.NewIncidentHandler$NewIncidentHandlerWrapper"
            commandId="org.wcs.smart.incident.new">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.DeleteIncidentHandler$DeleteIncidentHandlerWrapper"
            commandId="org.wcs.smart.incident.delete">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <instanceof
                        value="org.wcs.smart.incident.ui.IncidentEditorInput">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ShowIncidentFilterHandler$ShowIncidentFilterHandlerWrapper"
            commandId="org.wcs.smart.independentincident.filter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ImportIncidentHandler$ImportIncidentHandlerWrapper"
            commandId="org.wcs.smart.independentincident.import">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.ExportIncidentHandler$ExportIncidentHandlerWrapper"
            commandId="org.wcs.smart.independentincident.export">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.incident.ui.OpenIncidentHandler$OpenIncidentHandlerWrapper"
            commandId="org.wcs.smart.incident.open">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <instanceof
                        value="org.wcs.smart.incident.ui.IncidentEditorInput">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.incident.ui.IncidentEditor"
            default="false"
            icon="images/icons/obj16/incident.png"
            id="org.wcs.smart.incident.ui.IncidentEditor"
            name="%editor.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.help.toc">
      <toc
            file="help/html/toc.xml"
            primary="false">
      </toc>
   </extension>

</plugin>
