<?xml version="1.0" encoding="UTF-8"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	
	<parent>
		<groupId>org.wcs.smart.core</groupId>
		<artifactId>smart</artifactId>
		<version>7.4.0-SNAPSHOT</version>
		<relativePath>../pom-shared.xml</relativePath>
	</parent>
	
	<modelVersion>4.0.0</modelVersion>
	
	<artifactId>org.wcs.smart.core.patrol.query</artifactId>
	<name>Patrol Query Module</name>
	<packaging>bundle</packaging>
	<version>7.4.1-SNAPSHOT</version>
	
	<!-- without using the eclipse complier we get -->
	<!--  code too large for try statement errors -->
	<build>
		<plugins>
			<plugin>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.6.0</version>
				<configuration>
					<compilerId>eclipse</compilerId>
				</configuration>
        			<dependencies>
          				<dependency>
            					<groupId>org.codehaus.plexus</groupId>
            					<artifactId>plexus-compiler-eclipse</artifactId>
            					<version>2.8.1</version>
          				</dependency>
        			</dependencies>
      			</plugin>
    		</plugins>
  	</build>
  
	<dependencies>
		<dependency>
    			<groupId>org.wcs.smart.core</groupId>
    			<artifactId>org.wcs.smart.core.core</artifactId>
    			<version>${smart.version}</version>
		</dependency>
	
		<dependency>
	    		<groupId>org.wcs.smart.core</groupId>
    			<artifactId>org.wcs.smart.core.patrol</artifactId>
    			<version>${smart.version}</version>
		</dependency>
		<dependency>
    			<groupId>org.wcs.smart.core</groupId>
    			<artifactId>org.wcs.smart.core.query</artifactId>
    			<version>${smart.version}</version>
		</dependency>
	</dependencies>
</project>