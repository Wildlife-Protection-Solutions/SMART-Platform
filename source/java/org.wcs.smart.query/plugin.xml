<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.wcs.smart.query.export.format" name="Query Export Format" schema="schema/org.wcs.smart.query.export.format.exsd"/>
   <extension-point id="org.wcs.smart.query.property" name="Query Property" schema="schema/org.wcs.smart.query.property.exsd"/>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            class="org.wcs.smart.query.ui.definition.QueryDefView"
            icon="images/icons/view16/querypatrol.gif"
            id="org.wcs.smart.query.ui.QueryDefView"
            name="Smart Query Definition"
            restorable="true">
      </view>
      <view
            allowMultiple="false"
            class="org.wcs.smart.query.ui.queyfilter.QueryFilterView"
            icon="images/icons/view16/query_filter_op.png"
            id="org.wcs.smart.query.ui.QueryFilter"
            name="Query Filter"
            restorable="false">
      </view>
      <view
            class="org.wcs.smart.query.ui.querylist.QueryListView"
            icon="images/icons/view16/query_list.png"
            id="org.wcs.smart.query.QueryListView"
            name="Saved Queries/Summaries"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.query.ui.observation.QueryResultsEditor"
            default="false"
            icon="images/icons/view16/waypoint_query.png"
            id="org.wcs.smart.query.ui.QueryResultsEditor"
            name="Query Editor">
      </editor>
      <editor
            class="org.wcs.smart.query.ui.summary.SummaryEditor"
            default="false"
            icon="images/icons/view16/summary_query.png"
            id="org.wcs.smart.query.ui.SummaryEditor"
            name="Summary Editor">
      </editor>
      <editor
            class="org.wcs.smart.query.ui.patrol.PatrolQueryResultsEditor"
            default="false"
            icon="images/icons/obj16/patrol_query.png"
            id="org.wcs.smart.query.ui.PatrolQueryResultsEditor"
            name="Patrol Query">
      </editor>
      <editor
            class="org.wcs.smart.query.ui.gridded.GriddedEditor"
            default="false"
            icon="images/icons/view16/summary_query.png"
            id="org.wcs.smart.query.ui.GriddedEditor"
            name="Gridded Summary">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.query.internal.ui.QueryPerspective"
            icon="images/icons/view16/querypatrol.gif"
            id="org.wcs.smart.query.SmartQueryPerspective"
            name="Smart Query Perspective">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?before=org.wcs.smart.resetSeparator">
         <command
               commandId="org.wcs.smart.query.QueryPerspective"
               icon="images/icons/view16/querypatrol.gif"
               label="Show Query Perspective"
               mnemonic="Q"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="analyst">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="org.wcs.smart.query.queryToolbar">
            <command
                  commandId="org.wcs.smart.query.createQuery"
                  icon="images/icons/etool16/addquery.png"
                  label="Create Query"
                  mnemonic="Q"
                  style="push"
                  tooltip="Create a new database query.">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.query.createSummary"
                  icon="images/icons/etool16/addsummary.png"
                  label="Create Summary"
                  mnemonic="S"
                  style="push"
                  tooltip="Creates a new summary query">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.query.separator3"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.query.exportQuery"
                  icon="images/icons/etool16/exportquery.png"
                  label="Export Query"
                  style="push"
                  tooltip="Export the current query/summary">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.query.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.query.save"
                  icon="images/icons/etool16/save.gif"
                  id="org.wcs.smart.query.save.toolbar"
                  label="Save Query/Summary"
                  mnemonic="S"
                  tooltip="Saves the query or summary">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.query.saveAs"
                  icon="images/icons/etool16/saveas.gif"
                  label="Save Query/Summary As"
                  mnemonic="e"
                  tooltip="Save a copy of the query/summary">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.query.ui.QueryDefView">
         <command
               commandId="org.wcs.smart.query.save"
               icon="images/icons/etool16/save.gif"
               label="Save"
               mnemonic="S"
               tooltip="Save the query">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.query.clearQueryDefinition"
               icon="images/icons/etool16/clear.png"
               style="push"
               tooltip="Clear the query">
         </command>
         <command
               commandId="org.wcs.smart.query.runQuery"
               icon="images/icons/etool16/bullet_go.png"
               label="Run Current Query"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:org.wcs.smart.query.QueryListView">
         <command
               commandId="org.wcs.smart.query.AddFolder"
               icon="images/icons/etool16/folder_add.png"
               label="New Folder..."
               style="push"
               tooltip="adds a sub folder ">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="newfolder"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.query.renameFolder"
               label="Rename..."
               style="push"
               tooltip="rename the folder">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="rename"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.query.DeleteItem"
               icon="images/icons/etool16/delete.png"
               label="Delete"
               style="push"
               tooltip="Delete the selected item">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="selection">
                  <iterate
                        ifEmpty="false"
                        operator="or">
                     <test
                           args="delete"
                           property="org.wcs.smart.query.editable">
                     </test>
                  </iterate>
               </with>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.menu.patrol">
         <menu
               id="org.wcs.smart.menu.query"
               label="Query"
               mnemonic="Q">
            <command
                  commandId="org.wcs.smart.query.createQuery"
                  icon="images/icons/etool16/addquery.png"
                  label="New Query ..."
                  mnemonic="Q"
                  style="push"
                  tooltip="Create a new database query.">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.query.createSummary"
                  icon="images/icons/etool16/addsummary.png"
                  label="New Summary ..."
                  mnemonic="S"
                  style="push"
                  tooltip="Creates a new summary.">
            </command>
            <separator
                  name="org.wcs.smart.query.separator8"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.query.exportQuery"
                  icon="images/icons/etool16/exportquery.png"
                  label="Export Query/Summary ..."
                  mnemonic="x"
                  style="push"
                  tooltip="Exports the current query or summary">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.query.importQuery"
                  icon="images/icons/etool16/importquery.png"
                  label="Import Query/Summary ..."
                  mnemonic="i"
                  style="push"
                  tooltip="Imports a query or summary definition file">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.query.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.query.save"
                  icon="images/icons/etool16/save.gif"
                  id="org.wcs.smart.query.save.toolbar"
                  label="Save"
                  mnemonic="S"
                  tooltip="Save the query">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.query.saveAs"
                  icon="images/icons/etool16/saveas.gif"
                  label="Save As"
                  mnemonic="e"
                  tooltip="Save as a new query">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.query.SmartQueryPerspective">
                     </equals>
                  </with>
               </visibleWhen>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.file?before=org.wcs.menu.file.changeuserpassword">
         <separator
               name="org.wcs.smart.query.separator2"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.query.save"
               icon="images/icons/etool16/save.gif"
               id="org.wcs.smart.query.save.toolbar"
               label="Save Query/Summary"
               mnemonic="S"
               tooltip="Save the query or summary">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.query.saveAs"
               icon="images/icons/etool16/saveas.gif"
               label="Save Query/Summary As"
               mnemonic="e"
               tooltip="Saves a copy of the query/summary">
            <visibleWhen
                  checkEnabled="false">
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.query.SmartQueryPerspective">
                  </equals>
               </with>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator3"
               visible="true">
         </separator>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.query.QueryListView">
         <command
               commandId="org.wcs.smart.query.DeleteItem"
               icon="images/icons/etool16/delete.png"
               label="Delete"
               style="push"
               tooltip="Delete the selected item">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.trim.status">
         <toolbar
               id="org.wcs.smart.query.queryError">
            <control
                  class="org.wcs.smart.query.QueryErrorControlContribution">
            </control>
         </toolbar>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.query.QueryPerspective"
            name="Show Query Perspective">
      </command>
      <command
            id="org.wcs.smart.query.createQuery"
            name="Create Query">
      </command>
      <command
            description="Clear Query Definition"
            id="org.wcs.smart.query.clearQueryDefinition"
            name="Clear">
      </command>
      <command
            id="org.wcs.smart.query.runQuery"
            name="Run Query">
      </command>
      <command
            id="org.wcs.smart.query.exportQuery"
            name="Export Query">
      </command>
      <command
            id="org.wcs.smart.query.DeleteItem"
            name="Delete Query or Folder">
      </command>
      <command
            id="org.wcs.smart.query.AddFolder"
            name="Add Sub-Folder">
      </command>
      <category
            id="org.wcs.smart.query.category.save"
            name="name">
      </category>
      <command
            categoryId="org.wcs.smart.query.category.save"
            id="org.wcs.smart.query.save"
            name="Save Query">
      </command>
      <command
            categoryId="org.wcs.smart.query.category.save"
            id="org.wcs.smart.query.saveAs"
            name="Save As">
      </command>
      <command
            id="org.wcs.smart.query.renameFolder"
            name="Rename Query Folder">
      </command>
      <command
            id="org.wcs.smart.query.importQuery"
            name="Import Query">
      </command>
      <command
            id="org.wcs.smart.query.createSummary"
            name="Create Summary Query">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.query.internal.ui.ShowQueryPersepctiveHandler"
            commandId="org.wcs.smart.query.QueryPerspective">
      </handler>
      <handler
            class="org.wcs.smart.query.internal.ui.CreateQueryHandler"
            commandId="org.wcs.smart.query.createQuery">
      </handler>
      <handler
            class="org.wcs.smart.query.ui.ClearQueryHandler"
            commandId="org.wcs.smart.query.clearQueryDefinition">
         <enabledWhen>
            <with
                  variable="activeEditorId">
               <or>
                  <equals
                        value="org.wcs.smart.query.ui.QueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.SummaryEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.PatrolQueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.GriddedEditor">
                  </equals>
               </or>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.RunQueryHandler"
            commandId="org.wcs.smart.query.runQuery">
         <enabledWhen>
            <and>
               <with
                     variable="org.wcs.smart.query.ui.queryvalid">
                  <equals
                        value="true">
                  </equals>
               </with>
               <with
                     variable="activeEditorId">
                  <or>
                     <equals
                           value="org.wcs.smart.query.ui.QueryResultsEditor">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.ui.SummaryEditor">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.ui.PatrolQueryResultsEditor">
                     </equals>
                     <equals
                           value="org.wcs.smart.query.ui.GriddedEditor">
                     </equals>
                  </or>
               </with>
            </and>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.export.ExportQueryHandler"
            commandId="org.wcs.smart.query.exportQuery">
         <enabledWhen>
            <with
                  variable="activeEditorId">
               <or>
                  <equals
                        value="org.wcs.smart.query.ui.QueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.SummaryEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.PatrolQueryResultsEditor">
                  </equals>
               </or>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.querylist.DeleteItemHandler"
            commandId="org.wcs.smart.query.DeleteItem">
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <test
                        args="delete"
                        property="org.wcs.smart.query.editable">
                  </test>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.querylist.AddFolderHandler"
            commandId="org.wcs.smart.query.AddFolder">
         <activeWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <test
                        args="newfolder"
                        property="org.wcs.smart.query.editable">
                  </test>
               </iterate>
            </with>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.SaveQueryHandler"
            commandId="org.wcs.smart.query.save">
         <enabledWhen>
            <with
                  variable="activeEditorId">
               <or>
                  <equals
                        value="org.wcs.smart.query.ui.QueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.SummaryEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.PatrolQueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.GriddedEditor">
                  </equals>
               </or>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.SaveAsHandler"
            commandId="org.wcs.smart.query.saveAs">
         <enabledWhen>
            <with
                  variable="activeEditorId">
               <or>
                  <equals
                        value="org.wcs.smart.query.ui.QueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.SummaryEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.PatrolQueryResultsEditor">
                  </equals>
                  <equals
                        value="org.wcs.smart.query.ui.GriddedEditor">
                  </equals>
               </or>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.querylist.RenameFolderHandler"
            commandId="org.wcs.smart.query.renameFolder">
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <test
                        args="rename"
                        property="org.wcs.smart.query.editable">
                  </test>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.query.ui.qimport.ImportQueryHandler"
            commandId="org.wcs.smart.query.importQuery">
      </handler>
      <handler
            class="org.wcs.smart.query.internal.ui.CreateSummaryHandler"
            commandId="org.wcs.smart.query.createSummary">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.services">
      <sourceProvider
            provider="org.wcs.smart.query.ui.SourceProvider">
         <variable
               name="org.wcs.smart.query.ui.filteradd"
               priorityLevel="activePartId">
         </variable>
         <variable
               name="org.wcs.smart.query.ui.queryvalid"
               priorityLevel="activePartId">
         </variable>
         <variable
               name="org.wcs.smart.query.ui.querybuildertype"
               priorityLevel="activePartId">
         </variable>
      </sourceProvider>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.query.model.QueryFolder">
      </class>
      <class
            class="org.wcs.smart.query.model.Query">
      </class>
      <class
            class="org.wcs.smart.query.model.observation.ObservationQuery">
      </class>
      <class
            class="org.wcs.smart.query.model.SummaryQuery">
      </class>
      <class
            class="org.wcs.smart.query.model.patrol.PatrolQuery">
      </class>
      <class
            class="org.wcs.smart.query.model.SimpleQuery">
      </class>
      <class
            class="org.wcs.smart.query.model.GriddedQuery">
      </class>
   </extension>
   <extension
         point="org.eclipse.core.expressions.propertyTesters">
      <propertyTester
            class="org.wcs.smart.query.querylist.QueryFolderEditablePropertyTester"
            id="org.wcs.smart.query.isQueryFolderEditor"
            namespace="org.wcs.smart.query"
            properties="editable"
            type="java.lang.Object">
      </propertyTester>
      <propertyTester
            class="org.wcs.smart.query.querylist.RootFolderTester"
            id="org.wcs.smart.query.isRootFolder"
            namespace="org.wcs.smart.query"
            properties="isRootFolder"
            type="java.lang.Object">
      </propertyTester>
   </extension>
   <extension
         point="org.wcs.smart.query.export.format">
      <Exporter
            class="org.wcs.smart.query.export.ShapeQueryExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.query.export.CsvSimpleQueryExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.query.export.CsvSummaryExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.query.export.ObservationQueryDefinitionExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.query.export.SummaryQueryDefinitionExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.query.export.ShapePatrolQueryExporter">
      </Exporter>
   </extension>

</plugin>
