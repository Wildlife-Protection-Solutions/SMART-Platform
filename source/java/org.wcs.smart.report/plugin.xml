                  <instanceof
                        value="org.wcs.smart.report.model.Report">
                  </instanceof>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.report.internal.ui.ExportReportHandler$ExportReportHandlerWrapper"
            commandId="org.wcs.smart.report.exportReport">
      </handler>
      <handler
            class="org.wcs.smart.report.internal.ui.ImportReportHandler$ImportReportHandlerWrapper"
            commandId="org.wcs.smart.report.importReport">
      </handler>
      <handler
            class="org.wcs.smart.report.internal.ui.ImportLibraryHandler$ImportLibraryHandlerWrapper"
            commandId="org.wcs.smart.report.importLibrary">
         <enabledWhen>
            <and>
               <with
                     variable="activeWorkbenchWindow.activePerspective">
                  <equals
                        value="org.wcs.smart.report.ReportPerspective">
                  </equals>
               </with>
               <or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </and>
         </enabledWhen>
      </handler>
