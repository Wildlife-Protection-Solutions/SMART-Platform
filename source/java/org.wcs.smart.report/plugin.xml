      <handler
            class="org.wcs.smart.report.internal.ui.EditReportHandler$EditReportHandlerWrapper"
            commandId="org.wcs.smart.report.editReport">
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <test
                        args="edit"
                        property="org.wcs.smart.report.menu.editable">
                  </test>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.report.internal.ui.NewFolderHandler$NewFolderHandlerWrapper"
            commandId="org.wcs.smart.report.newFolder">
      </handler>
      <handler
            class="org.wcs.smart.report.internal.ui.RenameReportItem$RenameReportItemWrapper"
            commandId="org.wcs.smart.report.renameReportItem">
      </handler>
      <handler
            class="org.wcs.smart.report.internal.ui.DeleteReportItemHandler$DeleteReportItemHandlerWrapper"
            commandId="org.wcs.smart.report.deleteReportItem">
