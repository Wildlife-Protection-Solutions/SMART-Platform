<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.menu.ca">
         <menu
               id="org.wcs.smart.menu.patrol"
               label="&amp;Patrol">
            <command
                  commandId="org.wcs.smart.patrol.newPatrol"
                  label="&amp;Create New Patrol"
                  style="push">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.patrol.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.patrol.patrolOptions"
                  label="Patrol &amp;Options ..."
                  style="push">
               <visibleWhen
                     checkEnabled="true">
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.patrol.patrolMandate"
                  label="Patrol &amp;Mandates ..."
                  style="push">
               <visibleWhen
                     checkEnabled="true">
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.patrol.patrolTypes"
                  label="Patrol &amp;Types ..."
                  style="push">
               <visibleWhen
                     checkEnabled="true">
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.patrol.teamList"
                  label="Patrol Te&amp;ams ..."
                  style="push">
               <visibleWhen
                     checkEnabled="true">
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.patrol.patrolMandate"
            name="Show Patrol Mandate List">
      </command>
      <command
            id="org.wcs.smart.patrol.patrolTypes"
            name="Show Patrol Type List">
      </command>
      <command
            id="org.wcs.smart.patrol.patrolOptions"
            name="Show Patrol Options ">
      </command>
      <command
            id="org.wcs.smart.patrol.teamList"
            name="Show Team List">
      </command>
      <command
            id="org.wcs.smart.patrol.newPatrol"
            name="Create New Patrol">
      </command>
      <command
            id="org.wcs.smart.patrol.PatrolPerspective"
            name="Show Patrol Perspective">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.patrol.internal.ui.properties.handlers.ShowPatrolTypeHandler"
            commandId="org.wcs.smart.patrol.patrolTypes">
      </handler>
      <handler
            class="org.wcs.smart.patrol.internal.ui.properties.handlers.ShowPatrolMandateHandler"
            commandId="org.wcs.smart.patrol.patrolMandate">
      </handler>
      <handler
            class="org.wcs.smart.patrol.internal.ui.properties.handlers.ShowPatrolOptionsHandler"
            commandId="org.wcs.smart.patrol.patrolOptions">
      </handler>
      <handler
            class="org.wcs.smart.patrol.internal.ui.properties.handlers.ShowPatrolTeamsHandler"
            commandId="org.wcs.smart.patrol.teamList">
      </handler>
      <handler
            class="org.wcs.smart.patrol.internal.ui.properties.handlers.NewPatrolHandler"
            commandId="org.wcs.smart.patrol.newPatrol">
      </handler>
      <handler
            class="org.wcs.smart.patrol.internal.ui.ShowPatrolPersepctiveHandler"
            commandId="org.wcs.smart.patrol.PatrolPerspective">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.patrol.model.PatrolMandate">
      </class>
      <class
            class="org.wcs.smart.patrol.model.PatrolType">
      </class>
      <class
            class="org.wcs.smart.patrol.model.PatrolTransportType">
      </class>
      <class
            class="org.wcs.smart.patrol.model.PatrolOptions">
      </class>
      <class
            class="org.wcs.smart.patrol.model.Team">
      </class>
      <class
            class="org.wcs.smart.patrol.model.PatrolLeg">
      </class>
      <class
            class="org.wcs.smart.patrol.model.Patrol">
      </class>
      <class
            class="org.wcs.smart.patrol.model.PatrolLegDay">
      </class>
      <class
            class="org.wcs.smart.patrol.model.PatrolLegMember">
      </class>
      <class
            class="org.wcs.smart.patrol.model.Waypoint">
      </class>
      <class
            class="org.wcs.smart.patrol.model.WaypointAttachment">
      </class>
      <class
            class="org.wcs.smart.patrol.model.WaypointObservation">
      </class>
      <class
            class="org.wcs.smart.patrol.model.WaypointObservationAttribute">
      </class>
      <class
            class="org.wcs.smart.patrol.model.Track">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            class="org.wcs.smart.patrol.ui.PatrolListView"
            icon="images/icons/ctool16/patrol.png"
            id="org.wcs.smart.patrol.ui.PatrolListView"
            name="Patrol List View"
            restorable="false">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.patrol.ui.PatrolPerspective"
            id="org.wcs.smart.patrol.PatrolPerspective"
            name="Patrol Perspective">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="toolbar:org.eclipse.ui.main.toolbar">
            <command
                  commandId="org.wcs.smart.patrol.PatrolPerspective"
                  icon="images/icons/ctool16/patrol.png"
                  label="Show Patrol Perspective"
                  style="push">
            </command>
         </toolbar>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.patrol.ui.PatrolEditor"
            icon="images/icons/ctool16/patrol.png"
            id="org.wcs.smart.patrol.ui.PatrolEditor"
            name="Patrol Editor">
      </editor>
      <editor
            class="org.wcs.smart.patrol.ui.PatrolSummaryEditor"
            id="org.wcs.smart.patrol.ui.PatrolSummaryEditor"
            name="Patrol Summary Editor">
      </editor>
   </extension>

</plugin>
