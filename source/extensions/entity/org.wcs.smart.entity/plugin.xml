<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.entity.ui.typelist.EntityTypeListView$EntityTypeListViewWrapper"
            icon="images/icons/obj16/entitytype.png"
            id="org.wcs.smart.entity.typelist"
            name="%entitytype.view.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.observation.FieldDataPerspective">
         <view
               closeable="false"
               id="org.wcs.smart.entity.typelist"
               minimized="false"
               moveable="true"
               relationship="stack"
               relative="org.wcs.smart.fielddata.datafolder"
               showTitle="true"
               standalone="true"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.entity.ccca.EntityTypeCcaaPerspective"
            icon="images/icons/obj16/entitytype.png"
            id="org.wcs.smart.entity.ccaa.EntityTypePerspective"
            name="%perspective.ccaa.name">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater">
         <menu
               icon="images/icons/obj16/entitytype.png"
               id="org.wcs.smart.menu.entity"
               label="%entity.menu.label">
            <command
                  commandId="org.wcs.smart.entitytype.new"
                  mnemonic="%newentity.command.mnemonic"
                  style="push"
                  tooltip="%newentity.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.entity.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.entitytype.export"
                  mnemonic="%exportentitytype.command.mnemonic"
                  style="push"
                  tooltip="%exportentitytype.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.entitytype.import"
                  mnemonic="%importentitytype.command.mnemonic"
                  style="push"
                  tooltip="%importentitytype.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.entity.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.observation.perspective.show"
                  icon="images/icons/obj16/entitytype.png"
                  label="%viewentities.menu.name"
                  mnemonic="%showentities.command.mnemonic"
                  style="push"
                  tooltip="%showentities.command.tooltip">
               <parameter
                     name="org.wcs.smart.observation.perspective.show.focusview"
                     value="org.wcs.smart.entity.typelist">
               </parameter>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?endof=org.wcs.smart.perspective.fielddata">
         <command
               commandId="org.wcs.smart.observation.perspective.show"
               icon="images/icons/obj16/entitytype.png"
               id="org.wcs.smart.perspective.fielddata.entity"
               label="%viewentities.command.name1"
               mnemonic="%showentities.command.mnemonic"
               mode="FORCE_TEXT"
               style="radio"
               tooltip="%openentities.command.tooltip">
            <parameter
                  name="org.wcs.smart.observation.perspective.show.focusview"
                  value="org.wcs.smart.entity.typelist">
            </parameter>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="analyst">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.entity.typelist">
         <command
               commandId="org.wcs.smart.entitytype.delete"
               style="push"
               tooltip="%deleteentitytype.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.entitytype.new"
               style="push"
               tooltip="%newentitytype.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.entity.entitytypefilter"
               style="push"
               tooltip="%filter.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <test
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="true"
            locationURI="popup:org.wcs.smart.entity.typelist">
         <command
               commandId="org.wcs.smart.entitytype.delete"
               style="push"
               tooltip="%delete.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.menu.file.multipleCa">
         <menu
               id="org.wcs.smart.menu.ccaa.entity"
               label="%entity.menu.label">
            <command
                  commandId="org.wcs.smart.command.showperspective"
                  icon="images/icons/obj16/entitytype.png"
                  label="%viewentities.command.name"
                  mnemonic="%showentities.command.mnemonic"
                  style="push"
                  tooltip="%showentities.command.tooltip">
               <parameter
                     name="org.wcs.smart.perspectiveid"
                     value="org.wcs.smart.entity.ccaa.EntityTypePerspective">
               </parameter>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <not>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                  </not>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </and>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.file.multipleCa?before=org.wcs.smart.file.separator1">
         <command
               commandId="org.eclipse.ui.file.export"
               id="%file.exportmap.command.mnemonic"
               label="%menu.file.command.export.label"
               style="push"
               tooltip="%file.exportmap.command.tooltip">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <with
                        variable="activeWorkbenchWindow.activePerspective">
                     <equals
                           value="org.wcs.smart.entity.ccaa.EntityTypePerspective">
                     </equals>
                  </with>
                  <not>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                  </not>
               </and>
            </visibleWhen>
         </command>
         <separator
               name="org.wcs.smart.query.separator3"
               visible="true">
         </separator>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="vertical.org.wcs.smart.entity.toolbar1">
            <command
                  commandId="org.wcs.smart.entitytype.new"
                  label="%command.newtype.label"
                  mnemonic="%newentity.command.mnemonic"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%newentity.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.entity.typelist">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
         <toolbar
               id="vertical.org.wcs.smart.entity.toolbar2">
            <command
                  commandId="org.wcs.smart.entitytype.import"
                  label="%command.importtype.label"
                  mnemonic="%importentitytype.command.mnemonic"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%importentitytype.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.entity.typelist">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                  </and>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.entitytype.export"
                  label="%command.exporttype.label"
                  mnemonic="%exportentitytype.command.mnemonic"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%exportentitytype.command.tooltip">
               <visibleWhen
                     checkEnabled="false">
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.entity.typelist">
                     </test>
                     <or>
                        <test
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.entitytype.new"
            name="%newentitycommand.name">
      </command>
      <command
            id="org.wcs.smart.entitytype.delete"
            name="%deleteentities.command.name">
      </command>
      <command
            id="org.wcs.smart.entity.entitytypefilter"
            name="%filterentities.command.name">
      </command>
      <command
            id="org.wcs.smart.entitytype.import"
            name="%importentitytype.command.name">
      </command>
      <command
            id="org.wcs.smart.entitytype.export"
            name="%exportentitytype.command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.entitytype.delete"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/delete.png">
      </image>
      <image
            commandId="org.wcs.smart.entitytype.new"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/add.png">
      </image>
      <image
            commandId="org.wcs.smart.entity.entitytypefilter"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/filter.png">
      </image>
      <image
            commandId="org.wcs.smart.entitytype.export"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/export.png">
      </image>
      <image
            commandId="org.wcs.smart.entitytype.import"
            icon="platform:/plugin/org.wcs.smart/images/icons/shared16/import.png">
      </image>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.entity.ui.NewEntityHandler$NewEntityHandlerWrapper"
            commandId="org.wcs.smart.entitytype.new">
         <activeWhen>
            <and>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </and>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.DeleteEntityTypeHandler$DeleteEntityTypeHandlerWrapper"
            commandId="org.wcs.smart.entitytype.delete">
         <activeWhen>
            <and>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </and>
         </activeWhen>
         <enabledWhen>
            <with
                  variable="selection">
               <iterate
                     ifEmpty="false"
                     operator="or">
                  <or>
                     <instanceof
                           value="org.wcs.smart.entity.model.EntityType">
                     </instanceof>
                     <instanceof
                           value="org.wcs.smart.entity.ui.editor.EntityTypeEditorInput">
                     </instanceof>
                  </or>
               </iterate>
            </with>
         </enabledWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.OpenFilterDialogHandler$OpenFilterDialogHandlerWrapper"
            commandId="org.wcs.smart.entity.entitytypefilter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.ExportEntityTypeHandler$ExportEntityTypeHandlerWrapper"
            commandId="org.wcs.smart.entitytype.export">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.ImportEntityTypeHandler$ImportEntityTypeHandlerWrapper"
            commandId="org.wcs.smart.entitytype.import">
         <activeWhen>
            <and>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </and>
         </activeWhen>
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            ca_property=".entityType.conservationArea"
            class="org.wcs.smart.entity.model.Entity"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".entityType.conservationArea"
            class="org.wcs.smart.entity.model.EntityAttribute"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".id.entity.entityType.conservationArea"
            class="org.wcs.smart.entity.model.EntityAttributeValue"
            supportsCcaa="false">
      </class>
      <class
            class="org.wcs.smart.entity.model.EntityType"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.caDeleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DeleteEntityTypeAdvisor"
            class="org.wcs.smart.entity.model.EntityType">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DmAttributeDeleteAdvisor"
            class="org.wcs.smart.ca.datamodel.Attribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DmAttributeListItemDeleteAdvisor"
            class="org.wcs.smart.ca.datamodel.AttributeListItem">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DmAttributeTreeNodeDeleteAdvisor"
            class="org.wcs.smart.ca.datamodel.AttributeTreeNode">
      </DeleteAdvisor>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.entity.ui.editor.EntityTypeEditor"
            default="false"
            icon="images/icons/obj16/entitytype.png"
            id="org.wcs.smart.entity.editor.entitytype"
            name="%entitytype.editor.name">
      </editor>
   </extension>
   <extension
         point="org.locationtech.udig.catalog.ServiceExtension">
      <service
            class="org.wcs.smart.entity.map.FixedEntityServiceExtension"
            id="org.wcs.smart.udig.catalog.FixedEntityService"
            name="%fixed.entitytype.service.name">
      </service>
   </extension>
   <extension
         point="org.eclipse.core.runtime.adapters">
      <factory
            adaptableType="org.wcs.smart.entity.query.SightingResultItem"
            class="org.wcs.smart.entity.query.SightingResultItemAdapterFactory">
         <adapter
               type="org.wcs.smart.observation.model.Waypoint">
         </adapter>
      </factory>
      <factory
            adaptableType="org.wcs.smart.entity.map.EntityFeature"
            class="org.wcs.smart.entity.query.SightingResultItemAdapterFactory">
         <adapter
               type="org.wcs.smart.observation.model.Waypoint">
         </adapter>
      </factory>
   </extension>
   <extension
         point="org.wcs.smart.caTemplateCloner">
      <templateCloner
            class="org.wcs.smart.entity.EntityTemplateCloner"
            id="org.wcs.smart.entity.entityCloner">
         <require
               id="org.wcs.smart.conservationAreaCloner">
         </require>
      </templateCloner>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.entity.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.entity.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.query.exportFormat">
      <Exporter
            class="org.wcs.smart.entity.query.SightingQueryCsvExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.entity.query.SightingQueryShpExporter">
      </Exporter>
   </extension>
   <extension
         point="org.wcs.smart.birt.map.maplayer">
      <MapLayer
            maplayer="org.wcs.smart.entity.report.FixedEntityMapLayer">
      </MapLayer>
      <StyleProvider
            styleprovider="org.wcs.smart.entity.report.EntityTableStyleProvider">
      </StyleProvider>
   </extension>
   <extension
         point="org.wcs.smart.caDataModelAdvisor">
      <EditAdvisor
            advisor="org.wcs.smart.entity.internal.DmAttributeEditAdvisor">
      </EditAdvisor>
   </extension>
   <extension
         point="org.eclipse.help.toc">
      <toc
            file="help/html/toc.xml"
            primary="false">
      </toc>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.entity.upgrade.EntityDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.report.birt.query.smartTable">
      <TableCategory
            icon="images/icons/obj16/entitytype.png"
            id="org.wcs.smart.entity.tables"
            name="Entity Types">
      </TableCategory>
      <DynamicTable
            category="org.wcs.smart.entity.tables"
            class="org.wcs.smart.entity.report.DynamicSmartTables"
            supportsCcaa="true">
      </DynamicTable>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.entity.updatesite.ChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>

</plugin>
