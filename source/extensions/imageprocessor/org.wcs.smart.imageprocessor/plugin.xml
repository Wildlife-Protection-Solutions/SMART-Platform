<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?after=org.wcs.smart.observation.options">
         <command
               commandId="org.wcs.smart.imageprocessor.resize"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.imageprocessor.ui.ShowResizeHandler$ShowResizeHandlerWrapper"
            commandId="org.wcs.smart.imageprocessor.resize">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.imageprocessor.resize"
            name="%command.name">
      </command>
   </extension>

</plugin>
