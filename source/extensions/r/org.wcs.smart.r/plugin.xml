<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.r.plugin.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.r.plugin.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.r.plugin.RDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.r.plugin.ChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            class="org.wcs.smart.r.model.RScript"
            supportsCcaa="true">
      </class>
      <class
            class="org.wcs.smart.r.model.RQuery"
            supportsCcaa="true">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.caTemplateCloner">
      <templateCloner
            class="org.wcs.smart.r.plugin.CaTemplateCloner"
            id="org.wcs.smart.r.caCloner">
      </templateCloner>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.query?before=org.wcs.smart.query.separator.options">
         <command
               commandId="org.wcs.smart.r.scripts.manage.show"
               icon="images/icons/rlogo_16.png"
               label="%configure.command.label"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="analyst">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:org.wcs.smart.query.parts.itemlist?before=org.wcs.smart.query.separator1">
         <menu
               icon="images/icons/rlogo_16.png"
               id="org.wcs.smart.r.scripts.runlist"
               label="%run.menu.label">
            <dynamic
                  class="org.wcs.smart.r.ui.RunScriptMenuContribution"
                  id="org.wcs.smart.r.scripts.runlist.dynamic">
            </dynamic>
            <separator
                  name="org.wcs.smart.r.scripts.runlist.seperator.other"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.r.scirpt.run"
                  label="%other.menu.command.label"
                  style="push">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <iterate>
                  <instanceof
                        value="org.wcs.smart.query.ui.editor.QueryEditorInput">
                  </instanceof>
               </iterate>
            </visibleWhen>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.r.ui.editor.script.RScriptEditor"
            default="false"
            icon="images/icons/rlogo_16.png"
            id="org.wcs.smart.r.script.editor"
            name="%r.editor.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.r.scripts.manage.show"
            name="%configure.command.name">
      </command>
      <command
            id="org.wcs.smart.r.scirpt.run"
            name="%run.command.name">
         <commandParameter
               id="org.wcs.smart.r.scirpt.run.scriptuuid"
               name="R Script Uuid"
               optional="true">
         </commandParameter>
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.r.ui.ShowRScriptHandler$ShowRScriptHandlerWrapper"
            commandId="org.wcs.smart.r.scripts.manage.show">
      </handler>
      <handler
            class="org.wcs.smart.r.ui.RunRScriptHandler$RunRScriptHandlerWrapper"
            commandId="org.wcs.smart.r.scirpt.run">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            class="org.wcs.smart.r.ui.RPreferencePage"
            id="org.wcs.smart.preference.r"
            name="%preferences.page.name">
      </page>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.r.ui.view.script.RScriptView$RScriptViewWrapper"
            icon="images/icons/rlogo_16.png"
            id="org.wcs.smart.r.view.rscripts"
            name="R "
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.query.persepectives.single">
         <view
               id="org.wcs.smart.r.view.rscripts"
               minimized="false"
               relationship="stack"
               relative="org.wcs.smart.query.parts.itemlist"
               visible="true">
         </view>
      </perspectiveExtension>
      <perspectiveExtension
            targetID="org.wcs.smart.query.persepectives.multi">
         <view
               id="org.wcs.smart.r.view.rscripts"
               minimized="false"
               relationship="stack"
               relative="org.wcs.smart.query.parts.itemlist"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.wcs.smart.caFilestoreDir">
      <FilestoreDirectory
            directory="rscripts">
      </FilestoreDirectory>
   </extension>

</plugin>
