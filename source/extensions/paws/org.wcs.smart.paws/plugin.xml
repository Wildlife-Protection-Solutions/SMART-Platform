<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.paws.plugin.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.paws.plugin.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.paws.plugin.PawsDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.paws.plugin.ChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            class="org.wcs.smart.paws.model.PawsConfiguration"
            supportsCcaa="true">
      </class>
      <class
            ca_property=".configuration.conservationArea"
            class="org.wcs.smart.paws.model.PawsParameter"
            supportsCcaa="true">
      </class>
      <class
            class="org.wcs.smart.paws.model.PawsRun"
            supportsCcaa="true">
      </class>
      <class
            class="org.wcs.smart.paws.model.PawsService"
            supportsCcaa="true">
      </class>
      <class
            class="org.wcs.smart.paws.model.PawsWorkspace"
            supportsCcaa="true">
      </class>
      <class
            ca_property=".configuration.conservationArea"
            class="org.wcs.smart.paws.model.PawsClassification"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.caTemplateCloner">
      <templateCloner
            class="org.wcs.smart.paws.plugin.CaTemplateCloner"
            id="org.wcs.smart.paws.caclone">
         <require
               id="org.wcs.smart.QueryCloner">
         </require>
         <require
               id="org.wcs.smart.query.*">
         </require>
      </templateCloner>
   </extension>
   <extension
         point="org.wcs.smart.caFilestoreDir">
      <FilestoreDirectory
            directory="paws">
      </FilestoreDirectory>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.query?before=org.wcs.smart.query.separator.options">
         <command
               commandId="org.wcs.smart.paws.configuration.show"
               label="PAWS Server Configuration..."
               style="push">
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.paws.configuration.show"
            name="Show PAWS Configuration">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.paws.ui.ShowConfigurationHandler$ShowConfigurationHandlerWrapper"
            commandId="org.wcs.smart.paws.configuration.show">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.paws.ui.PawsView$PawsViewWrapper"
            icon="images/icons/run.png"
            id="org.wcs.smart.paws.view"
            name="PAWS "
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.query.persepectives.single">
         <view
               id="org.wcs.smart.paws.view"
               minimized="false"
               relationship="stack"
               relative="org.wcs.smart.query.parts.itemlist"
               visible="true">
         </view>
      </perspectiveExtension>
      <perspectiveExtension
            targetID="org.wcs.smart.query.persepectives.multi">
         <view
               id="org.wcs.smart.paws.view"
               minimized="false"
               relationship="stack"
               relative="org.wcs.smart.query.parts.itemlist"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.paws.ui.config.ConfigurationEditor"
            default="false"
            icon="images/icons/config.png"
            id="org.wcs.smart.paws.configuration.editor"
            name="PAWS Configuration">
      </editor>
      <editor
            class="org.wcs.smart.paws.ui.run.RunEditor"
            default="false"
            icon="images/icons/run.png"
            id="org.wcs.smart.paws.run.editor"
            name="PAWS Run">
      </editor>
   </extension>
   <extension
         point="org.wcs.smart.caLogin">
      <loginHandler
            clazz="org.wcs.smart.paws.LoginHandler">
      </loginHandler>
   </extension>

</plugin>
