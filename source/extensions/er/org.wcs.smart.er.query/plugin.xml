<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.wcs.smart.query.queryType">
      <QueryCategory
            html_description="&lt;p style=&quot;font-family:Verdana; font-size:12px; font-weight:bold;&quot;&gt;Survey Queries&lt;/p&gt;&lt;p style=&quot;font-family:Verdana; font-size:11px&quot;&gt;Query survey data providing survey and mission attributes in addition to data model items as filters and summary options.&lt;/p&gt;"
            id="org.wcs.smart.er.query.category.survey"
            name="Survey Queries">
      </QueryCategory>
      <QueryType
            QueryCategory="org.wcs.smart.er.query.category.survey"
            class="org.wcs.smart.er.query.model.SurveyObservationQueryType">
         <DefinitionPanel
               id="org.wcs.smart.query.er.survey.definition.filter"
               itemPanelId="org.wcs.smart.er.query.survey.filterItemPanel">
         </DefinitionPanel>
      </QueryType>
      <QueryType
            QueryCategory="org.wcs.smart.er.query.category.survey"
            class="org.wcs.smart.er.query.model.SurveyWaypointQueryType">
         <DefinitionPanel
               id="org.wcs.smart.query.er.survey.definition.filter"
               itemPanelId="org.wcs.smart.er.query.survey.filterItemPanel">
         </DefinitionPanel>
      </QueryType>
      <QueryType
            QueryCategory="org.wcs.smart.er.query.category.survey"
            class="org.wcs.smart.er.query.model.MissionTrackQueryType">
         <DefinitionPanel
               id="org.wcs.smart.query.er.survey.definition.filter.track"
               itemPanelId="org.wcs.smart.er.query.survey.filterItemPanel.misisonTrack">
         </DefinitionPanel>
      </QueryType>
      <QueryType
            QueryCategory="org.wcs.smart.er.query.category.survey"
            class="org.wcs.smart.er.query.model.MissionQueryType">
         <DefinitionPanel
               id="org.wcs.smart.query.er.survey.definition.filter"
               itemPanelId="org.wcs.smart.er.query.survey.filterItemPanel.trackObservation">
         </DefinitionPanel>
      </QueryType>
      <QueryType
            QueryCategory="org.wcs.smart.er.query.category.survey"
            class="org.wcs.smart.er.query.model.SurveySummaryQueryType">
         <DefinitionPanel
               id="org.wcs.smart.query.er.survey.definition.summary"
               itemPanelId="org.wcs.smart.er.query.survey.summaryItemPanel">
         </DefinitionPanel>
         <DefinitionPanel
               id="org.wcs.smart.er.survey.definition.filter.valuerate"
               itemPanelId="org.wcs.smart.er.query.survey.filterItemPanel.trackObservation">
         </DefinitionPanel>
      </QueryType>
      <QueryType
            QueryCategory="org.wcs.smart.er.query.category.survey"
            class="org.wcs.smart.er.query.model.SurveyGridQueryType">
         <DefinitionPanel
               id="org.wcs.smart.query.er.survey.definition.grid"
               itemPanelId="org.wcs.smart.er.query.survey.gridValueItemPanel">
         </DefinitionPanel>
         <DefinitionPanel
               id="org.wcs.smart.er.survey.definition.filter.valuerate"
               itemPanelId="org.wcs.smart.er.query.survey.filterItemPanel.trackObservation">
         </DefinitionPanel>
      </QueryType>
   </extension>
   <extension
         point="org.wcs.smart.query.queryItemPanel">
      <QueryItemPanel
            id="org.wcs.smart.er.query.survey.filterItemPanel"
            panel="org.wcs.smart.er.query.ui.panels.item.FilterItemPanel">
      </QueryItemPanel>
      <QueryItemPanel
            id="org.wcs.smart.er.query.survey.gridValueItemPanel"
            panel="org.wcs.smart.er.query.ui.panels.item.GriddedValueItemPanel">
      </QueryItemPanel>
      <QueryItemPanel
            id="org.wcs.smart.er.query.survey.summaryItemPanel"
            panel="org.wcs.smart.er.query.ui.panels.item.GroupByValueItemPanel">
      </QueryItemPanel>
      <QueryItemPanel
            id="org.wcs.smart.er.query.survey.filterItemPanel.misisonTrack"
            panel="org.wcs.smart.er.query.ui.panels.item.MissionTrackFilterItemPanel">
      </QueryItemPanel>
      <QueryItemPanel
            id="org.wcs.smart.er.query.survey.filterItemPanel.trackObservation"
            panel="org.wcs.smart.er.query.ui.panels.item.TrackObservationFilterItemPanel">
      </QueryItemPanel>
   </extension>
   <extension
         point="org.wcs.smart.query.queryDefinitionPanel">
      <QueryDefinitionPanel
            id="org.wcs.smart.query.er.survey.definition.filter"
            isMultiCa="true"
            isSingleCa="true"
            panel="org.wcs.smart.er.query.ui.panels.definition.FilterDefintionPanel">
      </QueryDefinitionPanel>
      <QueryDefinitionPanel
            id="org.wcs.smart.query.er.survey.definition.grid"
            isMultiCa="true"
            isSingleCa="true"
            panel="org.wcs.smart.er.query.ui.panels.definition.GriddedDefinitionPanel">
      </QueryDefinitionPanel>
      <QueryDefinitionPanel
            id="org.wcs.smart.query.er.survey.definition.summary"
            isMultiCa="true"
            isSingleCa="true"
            panel="org.wcs.smart.er.query.ui.panels.definition.SummaryDefinitionPanel">
      </QueryDefinitionPanel>
      <QueryDefinitionPanel
            id="org.wcs.smart.er.survey.definition.filter.valuerate"
            isMultiCa="true"
            isSingleCa="true"
            panel="org.wcs.smart.er.query.ui.panels.definition.SimpleValueRateFilterPanel">
      </QueryDefinitionPanel>
      <QueryDefinitionPanel
            id="org.wcs.smart.query.er.survey.definition.filter.track"
            isMultiCa="true"
            isSingleCa="true"
            panel="org.wcs.smart.er.query.ui.panels.definition.TrackFilterDefinitionPanel">
      </QueryDefinitionPanel>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.query.createQuery?before=org.wcs.smart.query.createunknown.separator2">
         <menu
               icon="images/icons/obj16/survey.png"
               id="org.wcs.smart.query.createquery.surveyquery"
               label="%surveyquery.menu.label"
               tooltip="%surveyquery.menu.tooltip">
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  icon="images/icons/obj16/survey_observation_query.png"
                  label="%surveyquery.observation.command.label"
                  style="pulldown"
                  tooltip="%surveyquery.observation.command.tooltip">
               <parameter
                     name="org.wcs.smart.query.type"
                     value="surveyobservation">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  icon="images/icons/obj16/survey_waypoint_query.png"
                  label="%surveyquery.incident.command.label"
                  style="push"
                  tooltip="%surveyquery.incident.command.tooltip">
               <parameter
                     name="org.wcs.smart.query.type"
                     value="surveywaypoint">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  icon="images/icons/obj16/survey_missiontrack_query.png"
                  label="%surveyquery.track.command.label"
                  style="push"
                  tooltip="%surveyquery.track.command.tooltip">
               <parameter
                     name="org.wcs.smart.query.type"
                     value="surveymissiontrack">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  icon="images/icons/obj16/survey_mission_query.png"
                  label="%surveyquery.mission.command.label"
                  style="push"
                  tooltip="%surveyquery.mission.command.tooltip">
               <parameter
                     name="org.wcs.smart.query.type"
                     value="surveymission">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  icon="images/icons/obj16/survey_summary_query.png"
                  label="%surveyquery.summary.command.label"
                  style="push"
                  tooltip="%surveyquery.summary.command.tooltip">
               <parameter
                     name="org.wcs.smart.query.type"
                     value="surveysummary">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.query.createUnknownQuery"
                  icon="images/icons/obj16/survey_gridded_query.png"
                  label="%surveyquery.grid.command.label"
                  style="push"
                  tooltip="%surveyquery.grid.command.tooltip">
               <parameter
                     name="org.wcs.smart.query.type"
                     value="surveygrid">
               </parameter>
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.menu.query.newquery?before=org.wcs.smart.query.newquery.separator2">
         <menu
               icon="images/icons/obj16/survey.png"
               id="org.wcs.smart.query.createquery.surveyquery"
               label="%surveyquery.menu.label1"
               tooltip="%surveyquery.menu.tooltip1">
            <visibleWhen
                  checkEnabled="false">
               <test
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.er.query.model.SurveyObservationQuery">
      </class>
      <class
            class="org.wcs.smart.er.query.model.SurveyWaypointQuery">
      </class>
      <class
            class="org.wcs.smart.er.query.model.SurveyGriddedQuery">
      </class>
      <class
            class="org.wcs.smart.er.query.model.SurveySummaryQuery">
      </class>
      <class
            class="org.wcs.smart.er.query.model.MissionQuery">
      </class>
      <class
            class="org.wcs.smart.er.query.model.MissionTrackQuery">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.er.query.ui.editor.SurveySimpleQueryResultEditor"
            default="false"
            icon="images/icons/obj16/survey_observation_query.png"
            id="org.wcs.smart.er.query.ui.SimpleQueryResultsEditor"
            name="%surveyquery.observation.editor.name">
      </editor>
      <editor
            class="org.wcs.smart.er.query.ui.editor.SurveyGriddedEditor"
            default="false"
            icon="images/icons/obj16/survey_gridded_query.png"
            id="org.wcs.smart.er.query.ui.GriddedEditor"
            name="%surveyquery.grid.editor.name">
      </editor>
      <editor
            class="org.wcs.smart.er.query.ui.editor.SurveySummaryEditor"
            default="false"
            icon="images/icons/obj16/survey_summary_query.png"
            id="org.wcs.smart.er.query.ui.SummaryEditor"
            name="%surveyquery.summary.editor.name">
      </editor>
   </extension>
   <extension
         point="org.wcs.smart.query.property">
      <queryproperty
            propertyName="Query Columns:"
            propertyProvider="org.wcs.smart.er.query.ui.ColumnQueryPropertyProvider">
      </queryproperty>
   </extension>
   <extension
         point="org.wcs.smart.ca.templateCloner">
      <templateCloner
            class="org.wcs.smart.er.query.internal.SurveyQueryCloner"
            id="org.wcs.smart.er.query.SurveyQueryCloner">
         <require
               id="org.wcs.smart.er.SurveyCloner">
         </require>
      </templateCloner>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.er.query.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="1.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.er.query.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="1.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.query.export.format">
      <Exporter
            class="org.wcs.smart.er.query.importexport.SurveyGridQueryDefinitionExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.er.query.importexport.SurveySimpleQueryDefinitionExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.er.query.importexport.SurveySummaryQueryDefinitionExporter">
      </Exporter>
      <Exporter
            class="org.wcs.smart.er.query.importexport.SurveyShapeQueryExporter">
      </Exporter>
   </extension>
   <extension
         point="org.wcs.smart.query.import">
      <QueryImporter
            class="org.wcs.smart.er.query.importexport.SurveyGridQueryDefinitionImporter">
      </QueryImporter>
      <QueryImporter
            class="org.wcs.smart.er.query.importexport.SurveySimpleQueryDefinitionImporter">
      </QueryImporter>
      <QueryImporter
            class="org.wcs.smart.er.query.importexport.SurveySummaryQueryDefinitionImporter">
      </QueryImporter>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrage">
      <dbUpgrader
            upgrader="org.wcs.smart.er.query.upgrade.ERDatabaseUpgrader">
      </dbUpgrader>
   </extension>

</plugin>
