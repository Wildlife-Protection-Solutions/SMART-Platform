<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.er.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="1.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.er.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="1.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrage">
      <dbUpgrader
            upgrader="org.wcs.smart.er.upgrade.ERDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.er.model.SurveyDesign">
      </class>
      <class
            class="org.wcs.smart.er.model.SamplingUnit">
      </class>
      <class
            ca_property=".waypoint.conservationArea"
            class="org.wcs.smart.er.model.SurveyWaypoint">
      </class>
      <class
            ca_property=".mission.survey.surveyDesign.conservationArea"
            class="org.wcs.smart.er.model.MissionTrack">
      </class>
      <class
            ca_property=".id.mission.survey.surveyDesign.conservationArea"
            class="org.wcs.smart.er.model.MissionPropertyValue">
      </class>
      <class
            ca_property=".id.surveyDesign.conservationArea"
            class="org.wcs.smart.er.model.MissionProperty">
      </class>
      <class
            ca_property=".attribute.conservationArea"
            class="org.wcs.smart.er.model.MissionAttributeListItem">
      </class>
      <class
            class="org.wcs.smart.er.model.MissionAttribute">
      </class>
      <class
            ca_property=".survey.surveyDesign.conservationArea"
            class="org.wcs.smart.er.model.Mission">
      </class>
      <class
            ca_property=".surveyDesign.conservationArea"
            class="org.wcs.smart.er.model.Survey">
      </class>
      <class
            ca_property=".id.member.conservationArea"
            class="org.wcs.smart.er.model.MissionMember">
      </class>
      <class
            ca_property=".surveyDesign.conservationArea"
            class="org.wcs.smart.er.model.SurveyDesignProperty">
      </class>
      <class
            class="org.wcs.smart.er.model.SamplingUnitAttribute">
      </class>
      <class
            ca_property=".id.attribute.conservationArea"
            class="org.wcs.smart.er.model.SamplingUnitAttributeValue">
      </class>
      <class
            ca_property=".id.attribute.conservationArea"
            class="org.wcs.smart.er.model.SurveyDesignSamplingUnitAttribute">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.observation.ObservationSource">
      <ObservationSource
            class="org.wcs.smart.er.model.SurveyWaypointSource">
      </ObservationSource>
   </extension>
   <extension
         point="org.wcs.smart.ca.filestoredir">
      <FilestoreDirectory
            directory="survey">
      </FilestoreDirectory>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.er.ui.SurveyDesignListView"
            icon="images/icons/obj16/survey.png"
            id="org.wcs.smart.er.surveyDesignListView"
            name="Surveys"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.observation.FieldDataPerspective">
         <view
               closeable="false"
               id="org.wcs.smart.er.surveyDesignListView"
               minimized="false"
               moveable="true"
               ratio="0.6"
               relationship="stack"
               relative="org.wcs.smart.fielddata.datafolder"
               showTitle="true"
               standalone="true"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater">
         <menu
               icon="images/icons/obj16/survey.png"
               id="org.wcs.smart.er.menu.survey"
               label="Survey">
            <command
                  commandId="org.wcs.smart.er.mission.new"
                  style="push"
                  tooltip="creates a new mission">
            </command>
            <command
                  commandId="org.wcs.smart.er.survey.new"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.er.surveydesign.new"
                  style="push"
                  tooltip="creates a new survey design">
            </command>
            <separator
                  name="org.wcs.smart.er.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.er.surveydesignexport"
                  label="Export Survey Designs"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.er.surveydesignimport"
                  label="Import Survey Designs"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.er.separator3"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.er.missionattributes.show"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.er.su.show"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.er.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.er.showsurveys"
                  icon="images/icons/obj16/survey.png"
                  label="View Surveys"
                  mnemonic="x"
                  style="push"
                  tooltip="displays list of surveys">
            </command>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.er.surveyDesignListView">
         <command
               commandId="org.wcs.smart.er.delete"
               style="push"
               tooltip="deletes the selected survey items">
         </command>
         <command
               commandId="org.wcs.smart.er.surveydesign.new"
               style="push"
               tooltip="creates a new survey design">
         </command>
         <command
               commandId="org.wcs.smart.er.survey.new"
               style="push">
         </command>
         <command
               commandId="org.wcs.smart.er.mission.new"
               style="push"
               tooltip="creates a new mission">
         </command>
         <command
               commandId="org.wcs.smart.er.filter"
               style="push"
               tooltip="Filters the view items">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?after=org.wcs.smart.perspective.fielddata">
         <command
               commandId="org.wcs.smart.er.showsurveys"
               icon="images/icons/obj16/survey.png"
               label="View Surveys"
               style="push"
               tooltip="displays list of surveys">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="popup:org.wcs.smart.er.surveyDesignListView">
         <command
               commandId="org.wcs.smart.er.editItem"
               style="push"
               tooltip="edits the selected item">
         </command>
         <separator
               name="org.wcs.smart.er.list.seperator.1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.er.mission.new"
               style="push"
               tooltip="creates a new mission">
         </command>
         <command
               commandId="org.wcs.smart.er.survey.new"
               style="push">
         </command>
         <separator
               name="org.wcs.smart.er.list.seperator.2"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.er.delete"
               style="push"
               tooltip="deletes the selected survey items">
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.er.ui.handlers.ShowSurveyHandler"
            commandId="org.wcs.smart.er.showsurveys">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.DeleteSurveyElementHandler"
            commandId="org.wcs.smart.er.delete">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.NewSurveyDesignHandler"
            commandId="org.wcs.smart.er.surveydesign.new">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.NewSurveyHandler"
            commandId="org.wcs.smart.er.survey.new">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.NewMissionHandler"
            commandId="org.wcs.smart.er.mission.new">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.ShowMissionAttributesHandler"
            commandId="org.wcs.smart.er.missionattributes.show">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.ShowSamplingUnitAttributesHandler"
            commandId="org.wcs.smart.er.su.show">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.FilterSurveyListItemsHandler"
            commandId="org.wcs.smart.er.filter">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.EditSurveyElementHandler"
            commandId="org.wcs.smart.er.editItem">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.SurveyDesignExportHandler"
            commandId="org.wcs.smart.er.surveydesignexport">
      </handler>
      <handler
            class="org.wcs.smart.er.ui.handlers.SurveyDesignImportHandler"
            commandId="org.wcs.smart.er.surveydesignimport">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.er.showsurveys"
            name="View Surveys">
      </command>
      <command
            id="org.wcs.smart.er.surveydesign.new"
            name="New Survey Design...">
      </command>
      <command
            id="org.wcs.smart.er.delete"
            name="Delete ...">
      </command>
      <command
            id="org.wcs.smart.er.survey.new"
            name="New Survey...">
      </command>
      <command
            id="org.wcs.smart.er.mission.new"
            name="New Mission ...">
      </command>
      <command
            id="org.wcs.smart.er.missionattributes.show"
            name="Mission Attributes ...">
      </command>
      <command
            id="org.wcs.smart.er.su.show"
            name="Sampling Unit Attributes ...">
      </command>
      <command
            id="org.wcs.smart.er.filter"
            name="Filter Items">
      </command>
      <command
            id="org.wcs.smart.er.editItem"
            name="Edit...">
      </command>
      <command
            id="org.wcs.smart.er.surveydesignexport"
            name="Export Survey Designs">
      </command>
      <command
            id="org.wcs.smart.er.surveydesignimport"
            name="Import Survey Designs">
      </command>
   </extension>
   <extension
         point="org.eclipse.core.runtime.adapters">
      <factory
            adaptableType="org.wcs.smart.er.ui.SurveyListTreeNode"
            class="org.wcs.smart.er.ui.AdapterFactory">
         <adapter
               type="org.eclipse.ui.progress.IDeferredWorkbenchAdapter">
         </adapter>
      </factory>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.er.surveydesign.new"
            icon="images/icons/obj16/survey_design_add.png">
      </image>
      <image
            commandId="org.wcs.smart.er.delete"
            icon="images/icons/etool16/delete.png">
      </image>
      <image
            commandId="org.wcs.smart.er.survey.new"
            icon="images/icons/obj16/survey_add.png">
      </image>
      <image
            commandId="org.wcs.smart.er.mission.new"
            icon="images/icons/obj16/mission_add.png">
      </image>
      <image
            commandId="org.wcs.smart.er.su.show"
            icon="images/icons/obj16/sampling_unit_attribute.png">
      </image>
      <image
            commandId="org.wcs.smart.er.filter"
            icon="images/icons/obj16/survey_design_filter.png">
      </image>
      <image
            commandId="org.wcs.smart.er.missionattributes.show"
            icon="images/icons/obj16/mission_attributes.png">
      </image>
      <image
            commandId="org.wcs.smart.er.surveydesignexport"
            icon="images/icons/obj16/survey_design_export.png">
      </image>
      <image
            commandId="org.wcs.smart.er.surveydesignimport"
            icon="images/icons/obj16/survey_design_import.png">
      </image>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.er.ui.surveydesign.editor.SurveyDesignEditor"
            default="false"
            icon="images/icons/obj16/survey_design.png"
            id="org.wcs.smart.er.SurveyDesignEditor"
            name="Survey Design Editor">
      </editor>
      <editor
            class="org.wcs.smart.er.ui.mision.editor.MissionEditor"
            default="false"
            icon="images/icons/obj16/mission.png"
            id="org.wcs.smart.er.ui.mission.MissionEditor"
            name="Mission Editor">
      </editor>
   </extension>
   <extension
         point="org.wcs.smart.ca.deleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.er.delete.MissionAttributeDeleteAdvisor"
            class="org.wcs.smart.er.model.MissionAttribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.er.delete.MissionAttributeListItemDeleteAdvisor"
            class="org.wcs.smart.er.model.MissionAttributeListItem">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.er.delete.EmployeeDeleteAdvisor"
            class="org.wcs.smart.ca.Employee">
      </DeleteAdvisor>
   </extension>
   <extension
         point="net.refractions.udig.catalog.ServiceExtension">
      <service
            class="org.wcs.smart.er.map.samplingunit.SamplingUnitServiceExtension"
            id="org.wcs.smart.udig.er.catalog.SmartSamplingUnitService"
            name="Survey Design Sampling Unit Service">
      </service>
   </extension>
   <extension
         point="org.wcs.smart.ca.templateCloner">
      <templateCloner
            class="org.wcs.smart.er.internal.CaTemplateCloner"
            id="org.wcs.smart.er.SurveyCloner">
         <require
               id="org.wcs.smart.conservationAreaCloner">
         </require>
         <require
               id="org.wcs.smart.dataentry.cmTemplateCloner">
         </require>
      </templateCloner>
   </extension>

</plugin>
