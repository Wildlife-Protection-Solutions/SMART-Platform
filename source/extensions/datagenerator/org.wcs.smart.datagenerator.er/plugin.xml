<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.datagenerator.er.ui.ErDataGeneratorView$ErDataGeneratorViewWrapper"
            icon="images/surveymission_generator.png"
            id="org.wcs.smart.datagenerator.er.ui.datageneratorview"
            name="%view.name"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.datagenerator.er.show"
            name="%command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.datagenerator.er.ui.ErDataGeneratorHandler$ErDataGeneratorHandlerWrapper"
            commandId="org.wcs.smart.datagenerator.er.show">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.er.menu.survey?before=org.wcs.smart.er.separator2">
         <command
               commandId="org.wcs.smart.datagenerator.er.show"
               icon="images/surveymission_generator.png"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>

</plugin>
