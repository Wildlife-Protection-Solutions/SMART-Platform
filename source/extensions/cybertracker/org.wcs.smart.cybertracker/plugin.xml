<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.wcs.smart.cybertracker.datasource" name="%extension-point.name" schema="schema/org.wcs.smart.cybertracker.datasource.exsd"/>
   <extension-point id="org.wcs.smart.cybertracker.alert" name="%extension-point.name.0" schema="schema/org.wcs.smart.cybertracker.alert.exsd"/>
   <extension-point id="org.wcs.smart.cybertracker.json.processor" name="Cybertracker JSON Processor" schema="schema/org.wcs.smart.cybertracker.json.processor.exsd"/>
   <extension-point id="org.wcs.smart.cybertracker.export.package.contribution" name="Export Package Contribution" schema="schema/org.wcs.smart.cybertracker.export.package.contribution.exsd"/>
   <extension-point id="org.wcs.smart.cybertracker.ctpackage" name="Cybertracker Package Extensions" schema="schema/org.wcs.smart.cybertracker.ctpackage.exsd"/>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater2">
         <menu
               icon="images/etool16/cybertracker16.png"
               id="org.wcs.smart.cybertracker.menu"
               label="%cybertracker.menu.label">
            <separator
                  name="org.wcs.smart.cybertracker.patrolseparator"
                  visible="false">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.surveyseparator"
                  visible="false">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.separator3"
                  visible="true">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.patrolpackagesep"
                  visible="false">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.surveypackagesep"
                  visible="false">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.exportseparator"
                  visible="false">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.cybertracker.import"
                  label="%cybertracker.import.command.label"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.cybertracker.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.cybertracker.properties"
                  label="%command.ctproperties.label"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.cybertracker.imageprocessingop"
                  label="%imageops.handler"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.cybertracker.patrolmetaseparator"
                  visible="false">
            </separator>
            <separator
                  name="org.wcs.smart.cybertracker.surveymetaseparator"
                  visible="false">
            </separator>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </menu>
         <menu
               icon="images/etool16/cybertracker16.png"
               id="org.wcs.smart.cybertracker2.menu"
               label="%menu.ct2.label">
            <command
                  commandId="org.wcs.smart.cybertracker.json.import"
                  label="%cybertracker.import.command.label"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.cybertracker.packages.show"
                  label="Packages..."
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.cybertracker2.separator.import"
                  visible="true">
            </separator>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="org.wcs.smart.cybertracker">
            <command
                  commandId="org.wcs.smart.cybertracker.import"
                  label="%cybertracker.import.command.label"
                  style="push">
               <visibleWhen
                     checkEnabled="false">
                  <and>
                     <or>
                        <test
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                        <test
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                     </or>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.cybertracker.import"
            name="%cybertracker.import.command.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.properties"
            name="%cybertracker.properties.command.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.imageprocessingop"
            name="%imageops.command">
      </command>
      <command
            id="org.wcs.smart.cybertracker.json.import"
            name="%command.json.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.packages.show"
            name="Ct Packages">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerImportHandler$CyberTrackerImportHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.import">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerPropertiesHandler$CyberTrackerPropertiesHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.properties">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerImgProcessingOpHandler$CyberTrackerImgProcessingOpHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.imageprocessingop">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.importer.json.CyberTrackerJsonImportHandler$CyberTrackerJsonImportHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.json.import">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.ctpackage.ui.ShowCtPackageHandler$ShowCtPackageHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.packages.show">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            class="org.wcs.smart.cybertracker.model.CyberTrackerPropertiesOption"
            supportsCcaa="false">
      </class>
      <class
            class="org.wcs.smart.cybertracker.model.CyberTrackerPropertiesProfile"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".profile.conservationArea"
            class="org.wcs.smart.cybertracker.model.CyberTrackerPropertiesProfileOption"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".id.model.conservationArea"
            class="org.wcs.smart.cybertracker.model.ConfigurableModelCtPropertiesProfile"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".waypoint.conservationArea"
            class="org.wcs.smart.cybertracker.model.CtIncidentLink"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.cybertracker.importer.CyberTrackerImportEditor"
            default="false"
            icon="images/etool16/cybertracker16.png"
            id="org.wcs.smart.cybertracker.CyberTrackerImportEditor"
            name="%cybertracker.editor.name">
      </editor>
      <editor
            class="org.wcs.smart.cybertracker.importer.json.JsonImportEditor"
            default="false"
            icon="images/etool16/cybertracker16.png"
            id="org.wcs.smart.cybertracker.importer.json.ImportEditor"
            name="%editor.import.json.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.cybertracker.import"
            icon="images/etool16/import.png">
      </image>
      <image
            commandId="org.wcs.smart.cybertracker.imageprocessingop"
            icon="images/etool16/camera.png">
      </image>
      <image
            commandId="org.wcs.smart.cybertracker.json.import"
            icon="images/etool16/import.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.caTemplateCloner">
      <templateCloner
            class="org.wcs.smart.cybertracker.CybertrackerTemplateCloner"
            id="org.wcs.smart.cybertrackerTemplateCloner">
         <require
               id="org.wcs.smart.conservationAreaCloner">
         </require>
         <require
               id="org.wcs.smart.dataentry.cmTemplateCloner">
         </require>
      </templateCloner>
   </extension>
   <extension
         point="org.eclipse.help.toc">
      <toc
            file="toc.xml"
            primary="false">
      </toc>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.caFilestoreDir">
      <FilestoreDirectory
            directory="Cybertracker">
      </FilestoreDirectory>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.cybertracker.upgrade.CtDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.cybertracker.updatesite.ChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
   <extension
         point="org.wcs.smart.dataentry.extradata">
      <tab
            content="org.wcs.smart.cybertracker.properties.ConfigurableModelEditorCyberTrackerTab">
      </tab>
   </extension>
   <extension
         point="org.wcs.smart.dataentry.xml">
      <contribution
            class="org.wcs.smart.cybertracker.xml.dataentry.Ct2CmXmlExtraDataContribution">
      </contribution>
   </extension>
   <extension
         point="org.wcs.smart.caLogin">
      <loginHandler
            clazz="org.wcs.smart.cybertracker.CleanUpLoginHandler">
      </loginHandler>
   </extension>

</plugin>
