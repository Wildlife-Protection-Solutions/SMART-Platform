<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker.menu?before=org.wcs.smart.cybertracker.patrolseparator">
         <command
               commandId="org.wcs.smart.cybertracker.patrol.export"
               label="%command.cybertracker.patrol.export.label1"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker2.menu?after=org.wcs.smart.cybertracker2.separator.import">
         <command
               commandId="org.wcs.smart.cybertracker.patrol.export.package"
               label="Export Patrol Package"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker.menu?before=org.wcs.smart.cybertracker.patrolmetaseparator">
         <command
               commandId="org.wcs.smart.patrol.patrolScreens"
               label="%command.cybertracker.patrol.meta.export.label"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.cybertracker">
         <command
               commandId="org.wcs.smart.cybertracker.patrol.export"
               label="%command.cybertracker.patrol.export.label1"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <or>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="manager">
                  </test>
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="dataentry">
                  </test>
               </or>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.cybertracker.patrol.export"
            name="%command.cybertracker.patrol.export.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.patrol.export.package"
            name="Export Patrol Package">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.cybertracker.patrol.handler.PatrolCTExportHandler$PatrolCTExportHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.patrol.export">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.patrol.handler.ExportPatrolCtPackageHandler$ExportPatrolCtPackageHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.patrol.export.package">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.cybertracker.patrol.export"
            icon="images/etool16/export.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.datasource">
      <datasource
            dataBuilder="org.wcs.smart.cybertracker.patrol.importer.PatrolCTDataBuilder"
            importEditorContent="org.wcs.smart.cybertracker.patrol.importer.PatrolCTImportEditorContent"
            name="patrol">
      </datasource>
      <datasource
            dataBuilder="org.wcs.smart.cybertracker.patrol.importer.PatrolCTDataBuilder"
            importEditorContent="org.wcs.smart.cybertracker.patrol.importer.PatrolCTImportEditorContent"
            name="null">
      </datasource>
      
      
   </extension>
   
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            ca_property=".patrolLeg.patrol.conservationArea"
            class="org.wcs.smart.cybertracker.patrol.model.CtPatrolLink"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.patrol.json.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.patrol.json.updatesite.OnInstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.cybertracker.patrol.json.updatesite.CtPatrolChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.cybertracker.patrol.json.updatesite.CtPatrolDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.json.processor">
      <JsonProcessor
            class="org.wcs.smart.cybertracker.patrol.json.PatrolJsonProcessor">
      </JsonProcessor>
   </extension>

</plugin>
