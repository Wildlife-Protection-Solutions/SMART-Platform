<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar?after=vertical.org.wcs.smart.patrol.toolbar2">
         <toolbar
               id="vertical.org.wcs.smart.cybertracker.patrol.toolbar1">
            <command
                  commandId="org.wcs.smart.cybertracker.packages.show"
                  icon="platform:/plugin/org.wcs.smart.cybertracker/images/etool16/smartmobileexport.png"
                  label="%exportpackage.command.label"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%command.export.tooltip">
               <visibleWhen>
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.patrol.ui.PatrolListView">
                     </test>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="analyst">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.cybertracker.navigation.show"
                  icon="platform:/plugin/org.wcs.smart.cybertracker/images/etool16/navigation_export.png"
                  label="%exportroute.command.label"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%exportroute.command.tooltip">
               <visibleWhen>
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.patrol.ui.PatrolListView">
                     </test>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="analyst">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar?after=vertical.org.wcs.smart.cybertracker.patrol.toolbar1">
         <toolbar
               id="vertical.org.wcs.smart.cybertracker.patrol.toolbar2">
            <command
                  commandId="org.wcs.smart.cybertracker.json.import"
                  icon="platform:/plugin/org.wcs.smart.cybertracker/images/etool16/smartmobileimport.png"
                  label="%import.command.label"
                  mode="FORCE_TEXT"
                  style="push"
                  tooltip="%command.import.tooltip">
               <visibleWhen>
                  <and>
                     <test
                           forcePluginActivation="true"
                           property="org.wcs.smart.caSingle">
                     </test>
                     <with
                           variable="activeWorkbenchWindow.activePerspective">
                        <equals
                              value="org.wcs.smart.observation.FieldDataPerspective">
                        </equals>
                     </with>
                     <test
                           property="org.wcs.smart.fielddata.focusview"
                           value="org.wcs.smart.patrol.ui.PatrolListView">
                     </test>
                     <or>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="admin">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="dataentry">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="analyst">
                        </test>
                        <test
                              forcePluginActivation="true"
                              property="org.wcs.smart.smartAdminUser"
                              value="manager">
                        </test>
                     </or>
                  </and>
               </visibleWhen>
            </command>
         </toolbar>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker2.menu?before=org.wcs.smart.cybertracker2.separator.import">
         <separator
               name="org.wcs.smart.cybertracker.patrol.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.cybertracker.patrol.cleanandfix"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.cybertracker.patrol.cleanandfix"
            name="Clean &amp;&amp; End Patrols">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.cybertracker.patrol.qa.CleanAndFixPatrolHandler$CleanAndFixPatrolHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.patrol.cleanandfix">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
   </extension>
   
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            ca_property=".patrolLeg.patrol.conservationArea"
            class="org.wcs.smart.cybertracker.patrol.model.CtPatrolLink"
            supportsCcaa="false">
      </class>
      <class
            class="org.wcs.smart.cybertracker.patrol.model.PatrolCtPackage"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".link.patrolLeg.patrol.conservationArea"
            class="org.wcs.smart.cybertracker.patrol.model.CtPatrolWpLink"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.patrol.json.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.cybertracker.patrol.json.updatesite.CtPatrolChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            requires="org.wcs.smart.cybertracker"
            upgrader="org.wcs.smart.cybertracker.patrol.json.updatesite.CtPatrolDatabaseUpgrader">
      </dbUpgrader>
      <pluginMapping
            new_plugin_id="org.wcs.smart.cybertracker.patrol"
            old_plugin_id="org.wcs.smart.connect.dataqueue.cybertracker.patrol"
            old_version_id="1.0">
      </pluginMapping>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.json.processor">
      <JsonProcessor
            class="org.wcs.smart.cybertracker.patrol.json.DesktopPatrolJsonProcessor">
      </JsonProcessor>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.ctpackage">
      <ctpackagemanager
            class="org.wcs.smart.cybertracker.patrol.ui.PatrolCtPackageManager">
      </ctpackagemanager>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.navigation">
      <targetprovider
            class="org.wcs.smart.cybertracker.patrol.navigation.PatrolTrackNavigationTargetProvider">
      </targetprovider>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.device">
      <device_id_provider
            provider="org.wcs.smart.cybertracker.patrol.SmartMobilePatrolDeviceProvider">
      </device_id_provider>
   </extension>
   <extension
         point="org.wcs.smart.patrol.contribution">
      <uieditor
            class="org.wcs.smart.cybertracker.patrol.ui.PatrolEditorContribution">
      </uieditor>
      <edit
            class="org.wcs.smart.cybertracker.patrol.PatrolEditContribution">
      </edit>
   </extension>
   <extension
         point="org.wcs.smart.patrol.query.contribution">
      <FilterItem
            filter="org.wcs.smart.cybertracker.patrol.query.MobileDeviceIdPatrolQueryFilter"
            viewer="org.wcs.smart.cybertracker.patrol.query.MobileDeviceIdPatrolQueryFilterViewer">
      </FilterItem>
      <GroupByItem
            groupby="org.wcs.smart.cybertracker.patrol.query.MobileDeviceIdParolGroupBy"
            viewer="org.wcs.smart.cybertracker.patrol.query.MobileDeviceIdGroupByPatrolContribution">
      </GroupByItem>
   </extension>
   <extension
         point="org.wcs.smart.caDeleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.cybertracker.patrol.PatrolTypeDeleteAdvisor"
            class="org.wcs.smart.patrol.model.PatrolType">
      </DeleteAdvisor>
   </extension>
</plugin>
