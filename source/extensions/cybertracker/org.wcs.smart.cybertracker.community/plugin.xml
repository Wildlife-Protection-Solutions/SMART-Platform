<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            ca_property=".waypoint.conservationArea"
            class="org.wcs.smart.cybertracker.community.model.CommunityWaypoint"
            supportsCcaa="false">
      </class>
      <class
            class="org.wcs.smart.cybertracker.community.model.CommunityCtPackage"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.observation.ObservationSource">
      <ObservationSource
            class="org.wcs.smart.cybertracker.community.model.CommunityWaypointSource"
            ui_provider="org.wcs.smart.cybertracker.community.ui.CommunityWaypointSourceProvider">
      </ObservationSource>
   </extension>
   <extension
         point="org.wcs.smart.independentincident.provider">
      <incidentprovider
            class="org.wcs.smart.cybertracker.community.CommunityIncidentProvider">
      </incidentprovider>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.cybertracker.community.ui.CommunityIncidentEditor"
            default="false"
            icon="images/icons/community.16.png"
            id="org.wcs.smart.cybertracker.community.ui.IncidentEditor"
            name="Community Editor">
      </editor>
   </extension>
   <extension
         point="org.eclipse.core.runtime.adapters">
      <factory
            adaptableType="org.wcs.smart.cybertracker.community.model.CommunityWaypoint"
            class="org.wcs.smart.cybertracker.community.WaypointAdapterFactory">
         <adapter
               type="org.wcs.smart.observation.model.Waypoint">
         </adapter>
      </factory>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.ctpackage">
      <ctpackagemanager
            class="org.wcs.smart.cybertracker.community.pkg.CommunityPackageManager">
      </ctpackagemanager>
   </extension>

</plugin>
