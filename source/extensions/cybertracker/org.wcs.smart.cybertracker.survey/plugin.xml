<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker.menu?before=org.wcs.smart.cybertracker.surveyseparator">
         <command
               commandId="org.wcs.smart.cybertracker.survey.export"
               label="%command.cybertracker.survey.export.label1"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker2.menu?after=org.wcs.smart.cybertracker2.separator.import">
         <command
               commandId="org.wcs.smart.cybertracker.survey.export.package"
               label="%exportsurvey.command.label"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.cybertracker.menu?before=org.wcs.smart.cybertracker.surveymetaseparator">
         <command
               commandId="org.wcs.smart.er.missionScreens"
               label="%command.cybertracker.survey.meta.export.label"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.cybertracker">
         <command
               commandId="org.wcs.smart.cybertracker.survey.export"
               label="%command.cybertracker.survey.export.label1"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.cybertracker.survey.export"
            name="%command.cybertracker.survey.export.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.survey.export.package"
            name="%exportsurvey.command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.cybertracker.survey.handler.SurveyCTExportHandler$SurveyCTExportHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.survey.export">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.survey.handler.ExportSurveyCtPackageHandler$ExportSurveyCtPackageHandlerWrapper"
            commandId="org.wcs.smart.cybertracker.survey.export.package">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.cybertracker.survey.export"
            icon="images/etool16/export.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.datasource">
      <datasource
            dataBuilder="org.wcs.smart.cybertracker.survey.importer.SurveyCTDataBuilder"
            importEditorContent="org.wcs.smart.cybertracker.survey.importer.SurveyCTImportEditorContent"
            name="survey">
      </datasource>
   </extension>

 <extension
         point="org.wcs.smart.hibernate.libs.mapping">
      <class
            ca_property=".mission.survey.surveyDesign.conservationArea"
            class="org.wcs.smart.cybertracker.survey.model.CtMissionLink"
            supportsCcaa="false">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.json.processor">
      <JsonProcessor
            class="org.wcs.smart.cybertracker.survey.json.MissionJsonProcessor">
      </JsonProcessor>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.cybertracker.survey.updatesite.DataQueueCtMissionDatabaseUpgrader">
      </dbUpgrader>
      <pluginMapping
            new_plugin_id="org.wcs.smart.cybertracker.survey"
            old_plugin_id="org.wcs.smart.connect.dataqueue.cybertracker.survey"
            old_version_id="1.0">
      </pluginMapping>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.cybertracker.survey.updatesite.DataQueueCtMissionChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
    <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.survey.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.survey.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
  
</plugin>
