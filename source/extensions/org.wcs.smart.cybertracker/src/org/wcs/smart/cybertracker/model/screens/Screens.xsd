	<xs:element name="Screens">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Root">
					<xs:complexType>
						<xs:sequence>
							<xs:element type="xs:string" name="Id" />
							<xs:element type="xs:string" name="Name" />
							<xs:element type="cts:Node" name="Node" maxOccurs="unbounded" minOccurs="0" />
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

