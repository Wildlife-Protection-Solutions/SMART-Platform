<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.wcs.smart.qa">
      <data_provider
            class="org.wcs.smart.qa.er.ErTrackDataProvider"
            image="platform:/plugin/org.wcs.smart.er/images/icons/obj16/mission.png">
         <qa_action
               class="org.wcs.smart.qa.er.ui.DeleteErTrackAction"
               image="platform:/plugin/org.wcs.smart/images/icons/shared16/goto.png">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.EditTrackAction"
               image="platform:/plugin/org.wcs.smart/images/icons/shared16/edit.png">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.OpenSourceMissionAction"
               image="platform:/plugin/org.wcs.smart/images/icons/shared16/goto.png">
         </qa_action>
      </data_provider>
      <data_provider
            class="org.wcs.smart.qa.er.ErWaypointDataProvider"
            image="platform:/plugin/org.wcs.smart.er/images/icons/obj16/mission.png">
         <qa_action
               class="org.wcs.smart.qa.er.ui.DeleteErWaypointAction"
               image="platform:/plugin/org.wcs.smart/images/icons/shared16/delete.png">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.EditWaypointAction"
               image="platform:/plugin/org.wcs.smart/images/icons/shared16/edit.png">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.OpenSourceMissionAction"
               image="platform:/plugin/org.wcs.smart/images/icons/shared16/goto.png">
         </qa_action>
      </data_provider>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.libs.interceptor">
      <integrator
            class="org.wcs.smart.qa.er.hibernate.ErQaIntegrator">
      </integrator>
   </extension>

</plugin>
