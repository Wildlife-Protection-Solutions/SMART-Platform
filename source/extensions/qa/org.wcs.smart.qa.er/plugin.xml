<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.wcs.smart.qa">
      <data_provider
            class="org.wcs.smart.qa.er.ErTrackDataProvider"
            image="platform:/plugin/org.wcs.smart.er/images/icons/obj16/mission.png">
         <qa_action
               class="org.wcs.smart.qa.er.ui.DeleteErTrackAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.EditTrackAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.OpenSourceMissionAction">
         </qa_action>
      </data_provider>
      <data_provider
            class="org.wcs.smart.qa.er.ErWaypointDataProvider"
            image="platform:/plugin/org.wcs.smart.er/images/icons/obj16/mission.png">
         <qa_action
               class="org.wcs.smart.qa.er.ui.DeleteErWaypointAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.EditWaypointAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.er.ui.OpenSourceMissionAction">
         </qa_action>
      </data_provider>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.interceptor">
      <integrator
            class="org.wcs.smart.qa.er.hibernate.ErQaIntegrator">
      </integrator>
   </extension>

