<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.wcs.smart.qa" name="org.wcs.smart.qa" schema="schema/org.wcs.smart.qa.exsd"/>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.qa.model.QaError"
            supportsCcaa="false">
      </class>
      <class
            class="org.wcs.smart.qa.model.QaRoutine"
            supportsCcaa="false">
      </class>
      <class
            ca_property=".qaRoutine.conservationArea"
            class="org.wcs.smart.qa.model.QaRoutineParameter"
            supportsCcaa="true">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.observation.options">
         <menu
               icon="images/icons/qa.png"
               label="Quality Assurance">
            <command
                  commandId="org.wcs.smart.qa.validation.manual"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.qa.validation.auto"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.qa.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.qa.routines.list"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.qa.routines.list"
            name="Configure QA Routines...">
      </command>
      <command
            id="org.wcs.smart.qa.validation.manual"
            name="Manual Data Validation">
      </command>
      <command
            id="org.wcs.smart.qa.validation.auto"
            name="Automated Data Validation Errors">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.qa.ui.handler.ShowQaRoutineHandler$ShowQaRoutineHandlerWrapper"
            commandId="org.wcs.smart.qa.routines.list">
      </handler>
      <handler
            class="org.wcs.smart.qa.ui.handler.NewManualValidationHandler$NewManualValidationHandlerWrapper"
            commandId="org.wcs.smart.qa.validation.manual">
      </handler>
      <handler
            class="org.wcs.smart.qa.ui.handler.NewAutoValidationHandler$NewAutoValidationHandlerWrapper"
            commandId="org.wcs.smart.qa.validation.auto">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.qa">
      <qa_routine
            class="org.wcs.smart.qa.routine.LocationRoutineType">
         <parameter_collector
               class="org.wcs.smart.qa.ui.routine.WaypointLocationParameterCollector">
         </parameter_collector>
      </qa_routine>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.qa.ui.view.ManualResultsEditor"
            default="false"
            icon="images/icons/manual_qa.png"
            id="org.wcs.smart.qa.data.validatation.manual"
            name="Manual Data Validation">
      </editor>
      <editor
            class="org.wcs.smart.qa.ui.view.AutomatedResultsEditor"
            default="false"
            icon="images/icons/auto_qa.png"
            id="org.wcs.smart.qa.data.validatation.automated"
            name="Automated Data Validation">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.qa.routines.list"
            icon="images/icons/qa_configure.png">
      </image>
      <image
            commandId="org.wcs.smart.qa.validation.auto"
            icon="images/icons/auto_qa.png">
      </image>
      <image
            commandId="org.wcs.smart.qa.validation.manual"
            icon="images/icons/manual_qa.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.changelog.installer">
      <ChangeLogTracker
            clazz="org.wcs.smart.qa.plugin.ChangeLogInstaller">
      </ChangeLogTracker>
   </extension>

</plugin>
