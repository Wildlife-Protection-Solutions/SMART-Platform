<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.wcs.smart.qa">
      <data_provider
            class="org.wcs.smart.qa.patrol.routine.PatrolWaypointDataProvider"
            image="platform:/plugin/org.wcs.smart.patrol/images/icons/obj16/patrol.png">
         <qa_action
               class="org.wcs.smart.qa.patrol.ui.OpenSourcePatrolAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.patrol.ui.EditWaypointAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.patrol.ui.DeletePatrolWaypointAction">
         </qa_action>
      </data_provider>
      <data_provider
            class="org.wcs.smart.qa.patrol.routine.PatrolTrackDataProvider"
            image="platform:/plugin/org.wcs.smart.patrol/images/icons/obj16/patrol.png">
         <qa_action
               class="org.wcs.smart.qa.patrol.ui.OpenSourcePatrolAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.patrol.ui.DeletePatrolTrackAction">
         </qa_action>
         <qa_action
               class="org.wcs.smart.qa.patrol.ui.EditTrackAction">
         </qa_action>
      </data_provider>
      <qa_routine
            class="org.wcs.smart.qa.patrol.routine.PatrolSpeedRoutineType">
         <parameter_collector
               class="org.wcs.smart.qa.patrol.ui.PatrolSpeedParameterCollector">
         </parameter_collector>
      </qa_routine>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.interceptor">
      <integrator
            class="org.wcs.smart.qa.patrol.hibernate.PatrolQaIntegrator">
      </integrator>
   </extension>

</plugin>
