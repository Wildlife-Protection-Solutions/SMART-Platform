   <extension
         point="org.wcs.smart.ca.deleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.i2.handlers.DeleteEmployeeAdvisor"
            class="org.wcs.smart.ca.Employee">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.i2.handlers.DeleteIntelAttributeAdvisor"
            class="org.wcs.smart.i2.model.IntelAttribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.i2.handlers.DeleteIntelAttributeListItemAdvisor"
            class="org.wcs.smart.i2.model.IntelAttributeListItem">
      </DeleteAdvisor>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.i2.ui.IntelDataAnalysisPerspective"
            id="org.wcs.smart.i2.IntelDataAnalysisPerspective"
            name="Intelligence Data Analysis Perspective">
      </perspective>
      <perspective
            class="org.wcs.smart.i2.ui.IntelDataAssessmentPerspective"
            id="org.wcs.smart.i2.IntelDataAssessmentPerspective"
            name="Intelligence Data Assessment Perspective">
      </perspective>
   </extension>
