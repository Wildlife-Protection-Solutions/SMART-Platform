         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="org.wcs.smart.i2.toolbar.perspective">
            <command
                  commandId="org.wcs.smart.command.showperspective"
                  label="Data Analysis Mode"
                  style="radio">
               <parameter
                     name="org.wcs.smart.perspectiveid"
                     value="org.wcs.smart.i2.IntelDataAnalysisPerspective">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.command.showperspective"
                  label="Data Assessment Mode"
                  style="radio">
               <parameter
                     name="org.wcs.smart.perspectiveid"
                     value="org.wcs.smart.i2.IntelDataAssessmentPerspective">
               </parameter>
            </command>
         </toolbar>
      </menuContribution>
   </extension>
