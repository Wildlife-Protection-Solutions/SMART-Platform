   <extension
         point="org.wcs.smart.ca.deleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.i2.handlers.DeleteEmployeeAdvisor"
            class="org.wcs.smart.ca.Employee">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.i2.handlers.DeleteIntelAttributeAdvisor"
            class="org.wcs.smart.i2.model.IntelAttribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.i2.handlers.DeleteIntelAttributeListItemAdvisor"
            class="org.wcs.smart.i2.model.IntelAttributeListItem">
      </DeleteAdvisor>
   </extension>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="org.wcs.smart.i2.ui.IntelDataAnalysisPerspective"
            id="org.wcs.smart.i2.IntelDataAnalysisPerspective"
            name="Intelligence Data Analysis Perspective">
      </perspective>
      <perspective
            class="org.wcs.smart.i2.ui.IntelDataAssessmentPerspective"
            id="org.wcs.smart.i2.IntelDataAssessmentPerspective"
            name="Intelligence Data Assessment Perspective">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?after=org.wcs.smart.menu.ca">
         <menu
               id="org.wcs.smart.i2.menu.main"
               label="Intelligence 2">
            <command
                  commandId="org.wcs.smart.i2.command.record.new"
                  label="New Record"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.i2.command.entity.new"
                  label="New Entity"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.i2.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.i2.command.entitytypelist.show"
                  label="Entity Types..."
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.i2.command.attributelist.show"
                  label="Intelligence Attributes..."
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.i2.command.relationshipgrouplist.show"
                  label="Relationship Groups..."
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.i2.command.relationshiptypelist.show"
                  label="Relationship Types..."
                  style="push">
            </command>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.eclipse.ui.main.toolbar">
         <toolbar
               id="org.wcs.smart.i2.toolbar.perspective">
            <command
                  commandId="org.wcs.smart.i2.command.perspective.open"
                  label="Data Analysis Mode"
                  style="radio">
               <parameter
                     name="org.wcs.smart.perspectiveid"
                     value="org.wcs.smart.i2.IntelDataAnalysisPerspective">
               </parameter>
            </command>
            <command
                  commandId="org.wcs.smart.i2.command.perspective.open"
                  label="Data Assessment Mode"
                  style="radio">
               <parameter
                     name="org.wcs.smart.perspectiveid"
                     value="org.wcs.smart.i2.IntelDataAssessmentPerspective">
               </parameter>
            </command>
         </toolbar>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.views">
      <view
            allowMultiple="false"
            class="org.wcs.smart.i2.ui.views.EntitySearchView$EntitySearchViewWrapper"
            icon="images/icons/obj16/entity_list.png"
            id="org.wcs.smart.i2.view.entitysearch"
            name="Entity Search"
            restorable="true">
      </view>
      <view
            allowMultiple="false"
            class="org.wcs.smart.i2.ui.views.WorkingSetView$WorkingSetViewWrapper"
            id="org.wcs.smart.i2.ui.view.workingset"
            name="Working Set"
            restorable="true">
      </view>
      <view
            class="org.wcs.smart.i2.ui.views.RecordsView$RecordsViewWrapper"
            icon="images/icons/obj16/script_list.png"
            id="org.wcs.smart.i2.ui.view.records"
            name="Records"
            restorable="true">
      </view>
      <view
            class="org.wcs.smart.i2.ui.views.QueryView$QueryViewWrapper"
            id="org.wcs.smart.i2.ui.view.queries"
            name="Queries"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.i2.ui.editors.QueryEditor"
            default="false"
            id="org.wcs.smart.i2.editor.query"
            name="Intelligence Query Editor">
      </editor>
      <editor
            class="org.wcs.smart.i2.ui.editors.record.RecordEditor"
            default="false"
            icon="images/icons/obj16/script.png"
            id="org.wcs.smart.i2.editor.record"
            name="Intelligence Record Query">
      </editor>
      <editor
            class="org.wcs.smart.i2.ui.editors.EntityEditor"
            default="false"
            id="org.wcs.smart.i2.editor.entity"
            name="Entity Editor">
      </editor>
      <editor
            class="org.wcs.smart.i2.ui.editors.IntelligenceMapEditor"
            default="false"
            icon="images/icons/eview16/map.png"
            id="org.wcs.smart.i2.editor.map"
            name="Map">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.i2.command.entitytypelist.show"
            name="Entity Types...">
      </command>
      <command
            id="org.wcs.smart.i2.command.attributelist.show"
            name="Intelligence Attributes...">
      </command>
      <command
            id="org.wcs.smart.i2.command.relationshiptypelist.show"
            name="Relationship Types...">
      </command>
      <command
            id="org.wcs.smart.i2.command.entity.new"
            name="New Entity">
      </command>
      <command
            id="org.wcs.smart.i2.command.relationshipgrouplist.show"
            name="Relationship Groups...">
      </command>
      <command
            id="org.wcs.smart.i2.command.record.new"
            name="New Intelligence Record">
      </command>
      <command
            id="org.wcs.smart.i2.command.perspective.open"
            name="Show Perspective">
         <commandParameter
               id="org.wcs.smart.perspectiveid"
               name="Perspective ID"
               optional="true">
         </commandParameter>
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.i2.ui.handler.ShowEntityTypeListDialogHandler$ShowEntityTypeListDialogHandlerWrapper"
            commandId="org.wcs.smart.i2.command.entitytypelist.show">
      </handler>
      <handler
            class="org.wcs.smart.i2.ui.handler.ShowAttributeListDialogHandler$ShowAttributeListDialogHandlerWrapper"
            commandId="org.wcs.smart.i2.command.attributelist.show">
      </handler>
      <handler
            class="org.wcs.smart.i2.ui.handler.ShowRelationshipTypeListDialogHandler$ShowRelationshipTypeListDialogHandlerWrapper"
            commandId="org.wcs.smart.i2.command.relationshiptypelist.show">
      </handler>
      <handler
            class="org.wcs.smart.i2.ui.handler.NewEntityDialogHandler$NewEntityDialogHandlerWrapper"
            commandId="org.wcs.smart.i2.command.entity.new">
      </handler>
      <handler
            class="org.wcs.smart.i2.ui.handler.ShowRelationshipGroupListDialogHandler$ShowRelationshipGroupListDialogHandlerWrapper"
            commandId="org.wcs.smart.i2.command.relationshipgrouplist.show">
      </handler>
      <handler
            class="org.wcs.smart.i2.ui.handler.NewRecordHandler$NewRecordHandlerWrapper"
            commandId="org.wcs.smart.i2.command.record.new">
      </handler>
      <handler
            class="org.wcs.smart.i2.ui.handler.ShowPerspectiveHandler$ShowPerspectiveHandlerWrapper"
            commandId="org.wcs.smart.i2.command.perspective.open">
      </handler>
