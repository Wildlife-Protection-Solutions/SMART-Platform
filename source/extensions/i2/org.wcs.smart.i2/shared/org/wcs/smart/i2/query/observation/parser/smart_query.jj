Operator NumberOp() :
{}
{
   (
    < EQUAL >
  | < NOTEQUAL >
  | < NOTEQUAL2 >
  | < GREATER >
  | < GREATEREQUAL >
  | < LESS >
  | < LESSEQUAL >
  )
  {
    return Operator.parse(token.image);
  }
}

Operator StringOp() :
{}
{
  (
   < CONTAINS >
  | < STREQUALS >
	| < NOT_CONTAINS >
  )
  {
    return Operator.parse(token.image);
  }
}

Operator DateOp() :
{
  String fulltoken = null;
}
{
  (
   < BETWEEN > {fulltoken = token.image;}
  |
  	< NOTBETWEEN > {fulltoken = token.image;}
 )
  {
    return Operator.parse(fulltoken);
  }
}

Operator BooleanOp() :
{}
{
  (
   < K_AND >
  | < K_OR>
  )
  {
    return Operator.parse(token.image);
  }
}

String MultiList() :
{
  String list = "";
} {
  (( < DM_KEY > { list=token.image; })(  ","  < DM_KEY > { list += "," + token.image; })*)
  {
    return list;
  }
}

AttributeFilter.GeometryProperty GeometryProperty() :
{}
{
   (
     < AREA > | 
     < PERIMETER >
   )
  {
    return AttributeFilter.GeometryProperty.valueOfKey(token.image);
  }
}