IQueryFilter RecordStringExpression():
{
  Operator op = null;
  String key = null;
  String value = null;
}
{
	( 
		<RATTRIBUTE_KEY_STRING> {key = token.image;}
		op = StringOp()
		< QUOTED_STRING > {value = token.image;}
	)
	{
  		return RecordAttributeFilter.create(key, op, value);
	}
}

IQueryFilter RecordNumberExpression():
{
  Operator op = null;
  String key = null;
  Double value = null;
}
{
	( 
		<RATTRIBUTE_KEY_NUMERIC> {key = token.image;}
		op = NumberOp()
		<NUMBER> {value = Double.parseDouble(token.image);}
	)
	{
  		return RecordAttributeFilter.create(key, op, value);
	}
}

IQueryFilter RecordKeyExpression():
{
  String op = null;
  String key = null;
  String value = null;
}
{
	(	  
		
	  	( 
			<RATTRIBUTE_KEY_LIST> {key = token.image;}
			<  EQUAL > {op = token.image;}
			< DM_KEY >  {value = token.image;}
		)

		/*|
		  	( 
			<RECORDSTATUS_KEY> {key = token.image;}
			<  EQUAL > {op = token.image;}
			< DM_KEY >  {value = token.image;}
			)
		|
		  	( 
			<RECORDSOURCE_KEY> {key = token.image;}
			<  EQUAL > {op = token.image;}
			< DM_KEY >  {value = token.image;}
			)
		*/
		|
		( 
			<RATTRIBUTE_KEY_EMPLOYEE> {key = token.image;}
			<  EQUAL > {op = token.image;}
			(< UUID > | < DM_KEY >)  {value = token.image;}
		)
				|
		( 
			<RATTRIBUTE_KEY_ENTITY> {key = token.image;}
			<  EQUAL > {op = token.image;}
			(< UUID > | < DM_KEY >)  {value = token.image;}
		)
	)
	{
  		return RecordAttributeFilter.create(key, value);
	}

}

IQueryFilter RecordBooleanExpression():
{
}
{
	
	<RATTRIBUTE_KEY_BOOLEAN > {return RecordAttributeFilter.create(token.image);}	
}










IQueryFilter EntityTypeFilter():
