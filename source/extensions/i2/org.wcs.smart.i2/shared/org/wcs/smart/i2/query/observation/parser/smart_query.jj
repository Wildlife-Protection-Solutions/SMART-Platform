IQueryFilter EntityFilter():
{
}
{
  < ENTITY_KEY >{return EntityFilter.create(token.image);}  
}

IQueryFilter AreaFilter():
{
}
{
  < AREA_KEY >{return AreaFilter.create(token.image);}  
