<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.i2.menu.main.importexport?after=org.wcs.smart.i2.command.record.import.xml">
         <separator
               name="org.wcs.smart.i2.migrate.separator1"
               visible="true">
         </separator>
         <command
               commandId="org.wcs.smart.i2.migrate.intelligence"
               icon="platform:/plugin/org.wcs.smart/images/icons/shared16/import.png"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        property="org.wcs.smart.i2.permission"
                        value="intel_admin">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.i2.migrate.entity"
               icon="platform:/plugin/org.wcs.smart/images/icons/shared16/import.png"
               style="push">
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <test
                        property="org.wcs.smart.i2.permission"
                        value="intel_admin">
                  </test>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.i2.migrate.intelligence.MigrateSmart6IntelligenceHandler$MigrateSmart6IntelligenceHandlerWrapper"
            commandId="org.wcs.smart.i2.migrate.intelligence">
      </handler>
      <handler
            class="org.wcs.smart.i2.migrate.entity.MigrateSmart6EntityHandler$MigrateSmart6EntityHandlerWrapper"
            commandId="org.wcs.smart.i2.migrate.entity">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.i2.migrate.intelligence"
            name="%command.intelligence.name">
      </command>
      <command
            id="org.wcs.smart.i2.migrate.entity"
            name="%command.entity.name">
      </command>
   </extension>

</plugin>
