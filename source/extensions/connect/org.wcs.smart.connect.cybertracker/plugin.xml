<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.connect.cybertracker.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="4.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.changeLogInstaller">
      <ChangeLogTracker
            clazz="org.wcs.smart.connect.cybertracker.updatesite.ConnectCtChangeTrackerInstaller">
      </ChangeLogTracker>
   </extension>
   <extension
         point="org.wcs.smart.dbUpgrade">
      <dbUpgrader
            upgrader="org.wcs.smart.connect.cybertracker.updatesite.ConnectCtDatabaseUpgrader">
      </dbUpgrader>
   </extension>
   <extension
         point="org.wcs.smart.connect.configure.optionpanel">
      <Panel
            class="org.wcs.smart.connect.cybertracker.CtxOptionsPanel">
      </Panel>
   </extension>
   <extension
         point="org.wcs.smart.changeLogEventHandler">
      <handler
            class="org.wcs.smart.connect.cybertracker.FilestoreWatcherConfigurator">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.ctpackage">
      <ctexportaction
            class="org.wcs.smart.connect.cybertracker.ctpackage.ExportCtPackageToConnect">
      </ctexportaction>
      <ctpackageproperty
            class="org.wcs.smart.connect.cybertracker.ctpackage.ConnectCtPackageProperties">
      </ctpackageproperty>
   </extension>
    <extension
         point="org.wcs.smart.cybertracker.navigation">
      <navigationexportaction
            class="org.wcs.smart.connect.cybertracker.navigation.ExportNavigationLayerToConnect">
      </navigationexportaction>
	  <navigationlayerproperty
            class="org.wcs.smart.connect.cybertracker.navigation.NavConnectUploadedDate">
      </navigationlayerproperty>
   </extension>
   <extension
         point="org.wcs.smart.cybertracker.export.package.contribution">
      <contribution
            contribution="org.wcs.smart.connect.cybertracker.ctpackage.ConnectUrlContribution">
      </contribution>
      <contribution
            contribution="org.wcs.smart.connect.cybertracker.ctpackage.ConnectDataContribution">
      </contribution>
      <contribution
            contribution="org.wcs.smart.connect.cybertracker.ctpackage.ConnectAlertContribution">
      </contribution>
   </extension>

</plugin>
