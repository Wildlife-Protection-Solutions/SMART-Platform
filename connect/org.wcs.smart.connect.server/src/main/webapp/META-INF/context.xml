<Context>

	<ResourceLink name="jdbc/smart" 
		global="org.wcs.smart.connect.datasource.postgresql" />
	
	<ResourceLink name="filestorelocation" 
		global="filestorelocation" />
	<ResourceLink name="dataqueue_cleanup_days" 
		global="dataqueue_cleanup_days" />
	<ResourceLink name="spatial_ref_sys_table" 
		global="spatial_ref_sys_table" />
	<ResourceLink name="number_background_threads" 
		global="number_background_threads" />
	<ResourceLink name="work_item_history_days_available" 
		global="work_item_history_days_available" />
	<ResourceLink name="changelog_cleanup_days" 
		global="changelog_cleanup_days" />
	<ResourceLink name="ca_export_days_available" 
		global="ca_export_days_available" />
	<ResourceLink name="sync_download_hours_available" 
		global="sync_download_hours_available" />
	<ResourceLink name="cleanup_task_interval_hours" 
		global="cleanup_task_interval_hours" />
		
	<Resource name="mail/Session" 
		auth="Container" 
		type="javax.mail.Session"
		mail.transport.protocol="smtps"
		mail.smtp.ssl.enable="true"
		mail.smtp.auth="true"
		mail.smtp.from="noreply@refractions.net"
		mail.smtp.host="smtp.googlemail.com"
		mail.smtp.user="noreply@refractions.net"
		password="dontrespondhere2"/>
		
	<Realm className="org.apache.catalina.realm.LockOutRealm">
		<Realm className="org.apache.catalina.realm.DataSourceRealm"
			dataSourceName="jdbc/smart" userTable="connect.users" userNameCol="username"
			userCredCol="password" userRoleTable="connect.user_roles"
			roleNameCol="role_id" localDataSource="true">
			<CredentialHandler
				className="org.wcs.smart.connect.apache.BcryptCredentialHandler" />
		</Realm>
	</Realm>

	
</Context>
  	