<Context>
	<Resource name="jdbc/smart" 
		auth="Container" 
		type="javax.sql.DataSource"
		username="smart" password="smart" 
		driverClassName="org.postgresql.Driver"
		url="jdbc:postgresql://192.168.50.131:5432/connectjeff" 
		maxActive="20"
		maxIdle="10" factory="org.apache.tomcat.jdbc.pool.DataSourceFactory" />
		
	<Resource name="mail/Session" 
		auth="Container" 
		type="javax.mail.Session"
		mail.transport.protocol="smtps"
		mail.smtp.ssl.enable="true"
		mail.smtp.auth="true"
		mail.smtp.from="noreply@refractions.net"
		mail.smtp.host="smtp.googlemail.com"
		mail.smtp.user="noreply@refractions.net"
		password="dontrespondhere2"/>
		
	<Realm className="org.apache.catalina.realm.LockOutRealm">
		<Realm className="org.apache.catalina.realm.DataSourceRealm"
			dataSourceName="jdbc/smart" userTable="connect.users" userNameCol="username"
			userCredCol="password" userRoleTable="connect.user_roles"
			roleNameCol="role_id" localDataSource="true">
			<CredentialHandler
				className="org.wcs.smart.connect.apache.BcryptCredentialHandler" />
		</Realm>
	</Realm>

	<!-- environment variables -->
	<!-- SMART Filestore Location -->
	<Environment name="filestorelocation" value="C:\\temp\\connect_datastore\\"
		type="java.lang.String" override="false" />
	<Environment name="spatial_ref_sys_table" value="public.spatial_ref_sys"
		type="java.lang.String" override="false" />
	<Environment name="number_background_threads" value="5"
		type="java.lang.Integer" override="false" />
	<Environment name="work_item_history_days_available" value="5"
		type="java.lang.Integer" override="false" />
	<Environment name="changelog_cleanup_days" value="5"
		type="java.lang.Integer" override="false" />
	<Environment name="ca_export_days_available" value="5"
		type="java.lang.Integer" override="false" />
	<Environment name="sync_download_hours_available" value="5"
		type="java.lang.Integer" override="false" />
	<Environment name="cleanup_task_interval_hours" value="5"
		type="java.lang.Integer" override="false" />
</Context>
  	