<Context>
  <Resource name="jdbc/smart"
            auth="Container"
            type="javax.sql.DataSource"
            username="smart"
            password="smart"
            driverClassName="org.postgresql.Driver"
            url="jdbc:postgresql://192.168.50.131:5432/connectemily"
            maxActive="20"
            maxIdle="10"
            factory="org.apache.tomcat.jdbc.pool.DataSourceFactory"
            removeAbandoned="true"
            removeAbandonedTimeout="300"
            logAbandoned="true"
            validationQuery="SELECT 1"
            testOnBorrow="true"/>
           
	<Realm className="org.apache.catalina.realm.LockOutRealm">
		<Realm className="org.apache.catalina.realm.DataSourceRealm"
			dataSourceName="jdbc/smart"
          	userTable="connect.users" userNameCol="username" 
          	userCredCol="password" userRoleTable="connect.user_roles" roleNameCol="role"
          	localDataSource="true">
				<CredentialHandler className="org.wcs.smart.connect.apache.BcryptCredentialHandler"/>
		</Realm>
  	</Realm>
  	
  	<!-- environment variables -->
  	<!-- SMART Filestore Location -->
  	<Environment name="filestorelocation" value="C:\\temp\\connect_datastore\\" type="java.lang.String" override="false"/>
  	
  	<!-- Number of background threads available for processing requests -->
	<Environment name="number_background_threads" value="4" type="java.lang.Integer" override="false"/>
	
	<!-- The number of hours to wait between running the cleanup task -->
	<!-- Set to -1 to never run cleanup (not recommended) -->
	<Environment name="cleanup_task_interval_hours" value="24" type="java.lang.Integer" override="false"/>
	
	<!--  number of hours that download packages will be kept in the file and -->
	<!--  make available to users (default 24 hours) --> 
	<Environment name="sync_download_hours_available" value="24" type="java.lang.Integer" override="false"/>
	
	<!--  number of days to keep records in the work_item table -->
	<!--  Once and item has finished processing, -->
	<!--  this table only tracks history and does not affect other areas of the software -->
	<!--  default 180 days; set to -1 to keep forever -->
	<Environment name="work_item_history_days_available" value="180" type="java.lang.Integer" override="false"/>
	
	<!--  number of days to keep conservation area exports -->
	<!--  when a user download a conservation area from connect, an -->
	<!--  export is created.  These exports are saved and reused if  -->
	<!--  no changes have uploaded to connect since the last download  -->
	<!--  default 180 days; set to -1 to keep forever -->
	<Environment name="ca_export_days_available" value="180" type="java.lang.Integer" override="false"/>
	
	<!--  number of days to keep items in the change log table -->
	<!--  once removed if a client requests an old item the  -->
	<!--  system will fail.  So this should be set to somthing substantially longer -->
	<!--  than how often clients will request changes. -->
	<!--  default 180 days; set to -1 to keep forever -->
	<Environment name="changelog_cleanup_days" value="180" type="java.lang.Integer" override="false"/>
</Context>