<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater2">
         <menu
               icon="images/etool16/cybertracker16.png"
               id="org.wcs.smart.cybertracker.menu"
               label="%cybertracker.menu.label">
            <command
                  commandId="org.wcs.smart.cybertracker.export"
                  label="%cybertracker.export.command.label"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.cybertracker.import"
                  label="%cybertracker.import.command.label"
                  style="push">
            </command>
            <separator
                  name="org.wcs.smart.cybertracker.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.cybertracker.properties"
                  label="%cybertracker.properties.command.label"
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.patrol.patrolScreens"
                  label="%cybertracker.patrol.screens.config.command.label"
                  style="push">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <and>
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                  </or>
                  <test
                        forcePluginActivation="true"
                        property="org.wcs.smart.caSingle">
                  </test>
               </and>
            </visibleWhen>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.cybertracker.export"
            name="%cybertracker.export.command.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.import"
            name="%cybertracker.import.command.name">
      </command>
      <command
            id="org.wcs.smart.cybertracker.properties"
            name="%cybertracker.properties.command.name">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerExportHandler"
            commandId="org.wcs.smart.cybertracker.export">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerImportHandler"
            commandId="org.wcs.smart.cybertracker.import">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerPropertiesHandler"
            commandId="org.wcs.smart.cybertracker.properties">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.cybertracker.model.CyberTrackerPropertiesOption">
      </class>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.cybertracker.importer.CyberTrackerImportEditor"
            default="false"
            icon="images/etool16/cybertracker16.png"
            id="org.wcs.smart.cybertracker.CyberTrackerImportEditor"
            name="%cybertracker.editor.name">
      </editor>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.cybertracker.export"
            icon="images/etool16/export.png">
      </image>
      <image
            commandId="org.wcs.smart.cybertracker.import"
            icon="images/etool16/import.png">
      </image>
   </extension>
   <extension
         point="org.wcs.smart.ca.templateCloner">
      <templateCloner
            class="org.wcs.smart.cybertracker.CybertrackerTemplateCloner"
            id="org.wcs.smart.cybertrackerTemplateCloner">
         <require
               id="org.wcs.smart.conservationAreaCloner">
         </require>
      </templateCloner>
   </extension>
   <extension
         point="org.eclipse.help.toc">
      <toc
            file="toc.xml"
            primary="false">
      </toc>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.updatesite.OnInstallAction"
            name="onInstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="2.0.0">
      </action>
   </extension>
   <extension
         point="org.eclipse.equinox.p2.engine.actions">
      <action
            class="org.wcs.smart.cybertracker.updatesite.OnUninstallAction"
            name="onUninstall"
            touchpointType="org.eclipse.equinox.p2.osgi"
            version="2.0.0">
      </action>
   </extension>
   <extension
         point="org.wcs.smart.ca.filestoredir">
      <FilestoreDirectory
            directory="Cybertracker">
      </FilestoreDirectory>
   </extension>

</plugin>
