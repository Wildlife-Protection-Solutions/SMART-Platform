<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu?before=org.wcs.smart.menu.help">
         <menu
               id="org.wcs.smart.cybertracker.menu"
               label="Cyber Tracker">
            <command
                  commandId="org.wcs.smart.cybertracker.export"
                  label="Export ..."
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.cybertracker.import"
                  label="Import ..."
                  style="push">
            </command>
            <command
                  commandId="org.wcs.smart.cybertracker.properties"
                  label="Properties ..."
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.cybertracker.export"
            name="CyberTracker Export">
      </command>
      <command
            id="org.wcs.smart.cybertracker.import"
            name="CyberTracker Import">
      </command>
      <command
            id="org.wcs.smart.cybertracker.properties"
            name="Properties">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerExportHandler"
            commandId="org.wcs.smart.cybertracker.export">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerImportHandler"
            commandId="org.wcs.smart.cybertracker.import">
      </handler>
      <handler
            class="org.wcs.smart.cybertracker.handler.CyberTrackerPropertiesHandler"
            commandId="org.wcs.smart.cybertracker.properties">
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            class="org.wcs.smart.cybertracker.model.CyberTrackerProperties">
      </class>
   </extension>

</plugin>
