<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.views">
      <view
            class="org.wcs.smart.entity.ui.typelist.EntityTypeListView"
            icon="images/icons/obj16/entitytype.png"
            id="org.wcs.smart.entity.typelist"
            name="Entity Types"
            restorable="true">
      </view>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="org.wcs.smart.observation.FieldDataPerspective">
         <view
               closeable="false"
               id="org.wcs.smart.entity.typelist"
               minimized="false"
               moveable="true"
               relationship="stack"
               relative="org.wcs.smart.fielddata.datafolder"
               showTitle="true"
               standalone="true"
               visible="true">
         </view>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.wcs.smart.fielddata?before=org.wcs.smart.fielddata.dataseparater">
         <menu
               icon="images/icons/obj16/entitytype.png"
               id="org.wcs.smart.menu.entity"
               label="Entity">
            <command
                  commandId="org.wcs.smart.entitytype.new"
                  mnemonic="n"
                  style="push"
                  tooltip="create a new entity">
               <visibleWhen
                     checkEnabled="false">
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.entity.separator1"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.entitytype.import"
                  mnemonic="i"
                  style="push"
                  tooltip="imports an entity type">
               <visibleWhen
                     checkEnabled="false">
                  <test
                        property="org.wcs.smart.smartAdminUser"
                        value="admin">
                  </test>
               </visibleWhen>
            </command>
            <command
                  commandId="org.wcs.smart.entitytype.export"
                  mnemonic="x"
                  style="push"
                  tooltip="exports an entity type">
               <visibleWhen
                     checkEnabled="false">
                  <or>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="admin">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="dataentry">
                     </test>
                     <test
                           property="org.wcs.smart.smartAdminUser"
                           value="manager">
                     </test>
                  </or>
               </visibleWhen>
            </command>
            <separator
                  name="org.wcs.smart.entity.separator2"
                  visible="true">
            </separator>
            <command
                  commandId="org.wcs.smart.entity.perspective"
                  icon="images/icons/obj16/entitytype.png"
                  mnemonic="p"
                  style="push"
                  tooltip="shows the entity perspective">
            </command>
            <visibleWhen
                  checkEnabled="false">
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
            </visibleWhen>
         </menu>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.perspectives?after=org.wcs.smart.perspective.fielddata">
         <command
               commandId="org.wcs.smart.entity.perspective"
               icon="images/icons/obj16/entitytype.png"
               style="push">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="false"
            locationURI="toolbar:org.wcs.smart.entity.typelist">
         <command
               commandId="org.wcs.smart.entitytype.delete"
               style="push"
               tooltip="Deletes the selected entity types">
            <visibleWhen
                  checkEnabled="false">
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.entitytype.new"
               style="push"
               tooltip="Creates a new entity type">
            <visibleWhen
                  checkEnabled="false">
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </visibleWhen>
         </command>
         <command
               commandId="org.wcs.smart.entity.entitytypefilter"
               style="push"
               tooltip="Opens a dialog where you can filter the entity types.">
         </command>
      </menuContribution>
      <menuContribution
            allPopups="true"
            locationURI="popup:org.wcs.smart.entity.typelist">
         <command
               commandId="org.wcs.smart.entitytype.delete"
               style="push"
               tooltip="Deletes the selected Entity Types">
            <visibleWhen
                  checkEnabled="false">
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </visibleWhen>
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="org.wcs.smart.entitytype.new"
            name="New Entity Type">
      </command>
      <command
            id="org.wcs.smart.entity.perspective"
            name="View Entity Types">
      </command>
      <command
            id="org.wcs.smart.entitytype.delete"
            name="Delete Entity Types">
      </command>
      <command
            id="org.wcs.smart.entity.entitytypefilter"
            name="Open Entity Type Filter Dialog">
      </command>
      <command
            id="org.wcs.smart.entitytype.import"
            name="Import Entity Type">
      </command>
      <command
            id="org.wcs.smart.entitytype.export"
            name="Export Entity Type">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="org.wcs.smart.entity.ui.NewEntityHandler"
            commandId="org.wcs.smart.entitytype.new">
         <activeWhen>
            <and>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </and>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.ViewEntityHandler"
            commandId="org.wcs.smart.entity.perspective">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.DeleteEntityTypeHandler"
            commandId="org.wcs.smart.entitytype.delete">
         <activeWhen>
            <and>
               <test
                     forcePluginActivation="true"
                     property="org.wcs.smart.caSingle">
               </test>
               <test
                     property="org.wcs.smart.smartAdminUser"
                     value="admin">
               </test>
            </and>
         </activeWhen>
      </handler>
      <handler
            class="org.wcs.smart.entity.ui.OpenFilterDialogHandler"
            commandId="org.wcs.smart.entity.entitytypefilter">
         <activeWhen>
            <test
                  forcePluginActivation="true"
                  property="org.wcs.smart.caSingle">
            </test>
         </activeWhen>
      </handler>
   </extension>
   <extension
         point="org.wcs.smart.hibernate.mapping">
      <class
            ca_property=".entityType.conservationArea"
            class="org.wcs.smart.entity.model.Entity">
      </class>
      <class
            ca_property=".entityType.conservationArea"
            class="org.wcs.smart.entity.model.EntityAttribute">
      </class>
      <class
            ca_property=".entity.entityType.conservationArea"
            class="org.wcs.smart.entity.model.EntityAttributeValue">
      </class>
      <class
            class="org.wcs.smart.entity.model.EntityType">
      </class>
   </extension>
   <extension
         point="org.wcs.smart.ca.deleteAdvisor">
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DeleteEntityTypeAdvisor"
            class="org.wcs.smart.entity.model.EntityType">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DmAttributeDeleteAdvisor"
            class="org.wcs.smart.ca.datamodel.Attribute">
      </DeleteAdvisor>
      <DeleteAdvisor
            advisor="org.wcs.smart.entity.event.DmAttributeListItemDeleteAdvisor"
            class="org.wcs.smart.ca.datamodel.AttributeListItem">
      </DeleteAdvisor>
   </extension>
   <extension
         point="org.eclipse.ui.commandImages">
      <image
            commandId="org.wcs.smart.entitytype.delete"
            icon="images/icons/etool16/deleteentitytype.png">
      </image>
      <image
            commandId="org.wcs.smart.entitytype.new"
            icon="images/icons/etool16/newentitytype.png">
      </image>
      <image
            commandId="org.wcs.smart.entity.perspective"
            icon="images/icons/obj16/entitytype.png">
      </image>
      <image
            commandId="org.wcs.smart.entity.entitytypefilter"
            icon="images/icons/etool16/filterentitytype.png">
      </image>
   </extension>
   <extension
         point="org.eclipse.ui.editors">
      <editor
            class="org.wcs.smart.entity.ui.editor.EntityTypeEditor"
            default="false"
            icon="images/icons/obj16/entitytype.png"
            id="org.wcs.smart.entity.editor.entitytype"
            name="Entity Type Editor">
      </editor>
   </extension>
   <extension
         point="net.refractions.udig.catalog.ServiceExtension">
      <service
            class="org.wcs.smart.entity.fixed.map.FixedEntityServiceExtension"
            id="org.wcs.smart.udig.catalog.FixedEntityService"
            name="Fixed Entity Types">
      </service>
   </extension>
   <extension
         point="org.eclipse.core.runtime.adapters">
      <factory
            adaptableType="org.wcs.smart.entity.query.SightingResultItem"
            class="org.wcs.smart.entity.query.SightingResultItemAdapterFactory">
         <adapter
               type="org.wcs.smart.observation.model.Waypoint">
         </adapter>
      </factory>
      <factory
            adaptableType="org.wcs.smart.entity.fixed.map.EntityFeature"
            class="org.wcs.smart.entity.query.SightingResultItemAdapterFactory">
         <adapter
               type="org.wcs.smart.observation.model.Waypoint">
         </adapter>
      </factory>
   </extension>

</plugin>
